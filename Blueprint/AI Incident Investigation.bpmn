<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:modeler="http://camunda.org/schema/modeler/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="d0de47f" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:process id="Process_vprqirj" name="AI Incident Investigation Blueprint" isExecutable="true">
    <bpmn:userTask id="ISMS_Incident_Review" name="ISMS Incident Review">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="Incident_Validation" />
        <zeebe:ioMapping>
          <zeebe:input source="=string(incident_object.impact)" target="suggested_impact" />
          <zeebe:input source="=string(incident_object.urgency)" target="suggested_urgency" />
          <zeebe:input source="=string(incident_object.impact)" target="ai_impact_orig" />
          <zeebe:input source="=string(incident_object.urgency)" target="ai_urgency_orig" />
          <zeebe:output source="=number(suggested_impact)" target="final_impact" />
          <zeebe:output source="=number(suggested_urgency)" target="final_urgency" />
          <zeebe:output source="=human_comment" target="human_comment" />
          <zeebe:output source="=audit_decision" target="audit_decision" />
          <zeebe:output source="=gdpr_decision" target="gdpr_decision" />
          <zeebe:output source="=gdpr_abort_comment" target="gdpr_abort_comment" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1rq39js</bpmn:incoming>
      <bpmn:outgoing>Flow_1jzlpls</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_1jzlpls" sourceRef="ISMS_Incident_Review" targetRef="Activity_0tgi495" />
    <bpmn:sequenceFlow id="Flow_1qc7jlo" sourceRef="Activity_1rkk3bi" targetRef="Prepare_Incident_Context" />
    <bpmn:serviceTask id="Activity_1rkk3bi" name="AI INCIDENT PLANNER" zeebe:modelerTemplate="io.camunda.connectors.aws.bedrock.v1" zeebe:modelerTemplateVersion="3" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:aws-bedrock:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="credentials" target="authentication.type" />
          <zeebe:input source="{{secrets.AWS_ACCESS_KEY_TW}}" target="authentication.accessKey" />
          <zeebe:input source="{{secrets.AWS_SECRET_KEY_TW}}" target="authentication.secretKey" />
          <zeebe:input source="eu-central-1" target="configuration.region" />
          <zeebe:input source="invokeModel" target="action" />
          <zeebe:input source="eu.anthropic.claude-sonnet-4-5-20250929-v1:0" target="data.modelId" />
          <zeebe:input source="={&#10;  &#34;anthropic_version&#34;: &#34;bedrock-2023-05-31&#34;,&#10;  &#34;max_tokens&#34;: 80,&#10;  &#34;temperature&#34;: 0,&#10;&#10;  &#34;system&#34;:&#10;&#34;Du bist ein deterministischer Incident Investigation Planning Agent für ein Security Operations Center (SOC).\n\n&#34; +&#10;&#10;&#34;Deine Aufgabe ist ausschließlich die Auswahl verpflichtender Ermittlungs- und Compliance-Tools.\n&#34; +&#10;&#34;Du führst KEINE Incident-Analyse durch.\n\n&#34; +&#10;&#10;&#34;Alle Regeln sind deterministisch verpflichtend.\n&#34; +&#10;&#34;Wenn eine Bedingung zutrifft, MUSS das zugehörige Tool ausgegeben werden.\n&#34; +&#10;&#34;Pflicht-Tools dürfen niemals ausgelassen werden.\n&#34; +&#10;&#34;Interne Modellbewertung ersetzt niemals ein Tool.\n\n&#34; +&#10;&#10;&#34;====================\n&#34; +&#10;&#34;AUSGABEFORMAT\n&#34; +&#10;&#34;====================\n\n&#34; +&#10;&#10;&#34;Antworte ausschließlich mit JSON.\n&#34; +&#10;&#34;Keine Erklärungen.\n&#34; +&#10;&#34;Keine Kommentare.\n&#34; +&#10;&#34;Kein Markdown.\n\n&#34; +&#10;&#10;&#34;FORMAT:\n&#34; +&#10;&#34;{\n&#34; +&#10;&#34;  \&#34;tools\&#34;: [\&#34;...\&#34;]\n&#34; +&#10;&#34;}&#34;,&#10;&#10;  &#34;messages&#34;: [&#10;    {&#10;      &#34;role&#34;: &#34;user&#34;,&#10;      &#34;content&#34;:&#10;&#10;&#34;Die grundlegende ISO-Sicherheitsanalyse wurde bereits durchgeführt.\n&#34; +&#10;&#34;Du entscheidest ausschließlich über zusätzliche Ermittlungs- und Compliance-Tools.\n\n&#34; +&#10;&#10;&#34;====================\n&#34; +&#10;&#34;VERFÜGBARE TOOLS\n&#34; +&#10;&#34;====================\n\n&#34; +&#10;&#10;&#34;threat_intel_lookup\n&#34; +&#10;&#34;→ Analyse externer IP-Adressen und Bedrohungsquellen\n\n&#34; +&#10;&#10;&#34;asset_lookup\n&#34; +&#10;&#34;→ Prüfung interner Systeme und Infrastruktur\n\n&#34; +&#10;&#10;&#34;check_gdpr_relevance\n&#34; +&#10;&#34;→ Prüfung möglicher DSGVO-Relevanz\n\n&#34; +&#10;&#10;&#34;====================\n&#34; +&#10;&#34;TOOL-REGELN\n&#34; +&#10;&#34;====================\n\n&#34; +&#10;&#10;&#34;threat_intel_lookup\n&#34; +&#10;&#34;→ MUSS verwendet werden, wenn eine KONKRETE externe IP-Adresse vorhanden ist\n\n&#34; +&#10;&#10;&#34;Begriffe wie:\n&#34; +&#10;&#34;- externes Netzwerk\n&#34; +&#10;&#34;- externe Verbindung\n&#34; +&#10;&#34;- Internet\n&#34; +&#10;&#34;- externe Aktivität\n\n&#34; +&#10;&#10;&#34;reichen NICHT aus.\n\n&#34; +&#10;&#10;&#34;asset_lookup\n&#34; +&#10;&#34;→ MUSS verwendet werden, wenn interne Systeme erkannt werden\n\n&#34; +&#10;&#10;&#34;Beispiele für interne Systeme:\n&#34; +&#10;&#34;- DB-\n&#34; +&#10;&#34;- AUTH-\n&#34; +&#10;&#34;- FS-\n&#34; +&#10;&#34;- APP-\n&#34; +&#10;&#34;- ADMIN-\n&#34; +&#10;&#34;- PAY-\n&#34; +&#10;&#34;- CRM-\n&#34; +&#10;&#34;- Server\n&#34; +&#10;&#34;- Fileserver\n&#34; +&#10;&#34;- Datenbank\n&#34; +&#10;&#34;- internes System\n&#34; +&#10;&#34;- API\n&#34; +&#10;&#34;- CRM-System\n\n&#34; +&#10;&#10;&#34;check_gdpr_relevance\n&#34; +&#10;&#34;→ MUSS verwendet werden, wenn BOTH gelten:\n\n&#34; +&#10;&#10;&#34;1. Hinweise auf personenbezogene Daten oder Benutzerkonten\n&#34; +&#10;&#34;Beispiele:\n&#34; +&#10;&#34;- Kundendaten\n&#34; +&#10;&#34;- Login-Daten\n&#34; +&#10;&#34;- Benutzerkonten\n&#34; +&#10;&#34;- E-Mail-Adressen\n&#34; +&#10;&#34;- personenbezogene Daten\n&#34; +&#10;&#34;- Kundenprofile\n&#34; +&#10;&#34;- Kontaktdaten\n&#34; +&#10;&#34;- User-IDs\n\n&#34; +&#10;&#10;&#34;UND\n\n&#34; +&#10;&#10;&#34;2. Hinweise auf Zugriff, Leak oder Kompromittierung\n&#34; +&#10;&#34;Beispiele:\n&#34; +&#10;&#34;- erfolgreicher Login\n&#34; +&#10;&#34;- unbefugter Zugriff\n&#34; +&#10;&#34;- Datenabfluß\n&#34; +&#10;&#34;- Exfiltration\n&#34; +&#10;&#34;- Leak\n&#34; +&#10;&#34;- kompromittierte Benutzerkonten\n&#34; +&#10;&#34;- Credential Theft\n&#34; +&#10;&#34;- Datenleck\n\n&#34; +&#10;&#10;&#34;Unsichere Formulierungen wie:\n&#34; +&#10;&#34;- möglicherweise\n&#34; +&#10;&#34;- könnte\n&#34; +&#10;&#34;- potenziell\n&#34; +&#10;&#34;- eventuell\n\n&#34; +&#10;&#10;&#34;verhindern die DSGVO-Prüfung NICHT.\n\n&#34; +&#10;&#10;&#34;====================\n&#34; +&#10;&#34;AUSSCHLUSSREGEL DSGVO\n&#34; +&#10;&#34;====================\n\n&#34; +&#10;&#10;&#34;Rein technische Netzwerkaktivität ohne Personenbezug ist KEIN DSGVO-Fall.\n\n&#34; +&#10;&#10;&#34;Dies gilt insbesondere für:\n&#34; +&#10;&#34;- DNS-Aktivität\n&#34; +&#10;&#34;- Reconnaissance\n&#34; +&#10;&#34;- Netzwerktraffic\n&#34; +&#10;&#34;- Portscans\n&#34; +&#10;&#34;- Infrastrukturkommunikation\n&#34; +&#10;&#34;- fehlgeschlagene Login-Versuche\n\n&#34; +&#10;&#10;&#34;====================\n&#34; +&#10;&#34;KOMBINATIONEN\n&#34; +&#10;&#34;====================\n\n&#34; +&#10;&#10;&#34;IP + internes System\n&#34; +&#10;&#34;→ threat_intel_lookup + asset_lookup\n\n&#34; +&#10;&#10;&#34;IP + DSGVO\n&#34; +&#10;&#34;→ threat_intel_lookup + check_gdpr_relevance\n\n&#34; +&#10;&#10;&#34;Internes System + DSGVO\n&#34; +&#10;&#34;→ asset_lookup + check_gdpr_relevance\n\n&#34; +&#10;&#10;&#34;Alle Bedingungen erfüllt\n&#34; +&#10;&#34;→ threat_intel_lookup + asset_lookup + check_gdpr_relevance\n\n&#34; +&#10;&#10;&#34;====================\n&#34; +&#10;&#34;BEISPIELE\n&#34; +&#10;&#34;====================\n\n&#34; +&#10;&#10;&#34;Externe IP scannt Internet\n&#34; +&#10;&#34;{ \&#34;tools\&#34;: [\&#34;threat_intel_lookup\&#34;] }\n\n&#34; +&#10;&#10;&#34;Zugriff auf ADMIN-01\n&#34; +&#10;&#34;{ \&#34;tools\&#34;: [\&#34;asset_lookup\&#34;] }\n\n&#34; +&#10;&#10;&#34;Kreditkarten-Exfiltration über API\n&#34; +&#10;&#34;{ \&#34;tools\&#34;: [\&#34;threat_intel_lookup\&#34;,\&#34;asset_lookup\&#34;,\&#34;check_gdpr_relevance\&#34;] }\n\n&#34; +&#10;&#10;&#34;DNS-Anomalie\n&#34; +&#10;&#34;{ \&#34;tools\&#34;: [] }\n\n&#34; +&#10;&#10;&#34;Fehlgeschlagene Login-Versuche\n&#34; +&#10;&#34;{ \&#34;tools\&#34;: [] }\n\n&#34; +&#10;&#10;&#34;====================\n&#34; +&#10;&#34;INCIDENT\n&#34; +&#10;&#34;====================\n\n&#34; +&#10;&#10;&#34;\&#34;\&#34;\&#34;\n&#34; +&#10;&#10;(if sim_input != null and sim_input.incident_topic != null&#10; then string(sim_input.incident_topic)&#10; else &#34;kein Incident Text verfügbar&#34;) +&#10;&#10;&#34;\n\&#34;\&#34;\&#34;&#34;&#10;    }&#10;  ]&#10;}" target="data.payload" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="3" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.aws.bedrock.v1" />
          <zeebe:header key="resultVariable" value="tools" />
          <zeebe:header key="resultExpression" value="={&#10;  &#34;raw&#34;: body.content[1].text,&#10;&#10;  &#34;clean_json&#34;:&#10;    trim(&#10;      replace(&#10;        replace(&#10;          body.content[1].text,&#10;          &#34;```json&#34;,&#10;          &#34;&#34;&#10;        ),&#10;        &#34;```&#34;,&#10;        &#34;&#34;&#10;      )&#10;    ),&#10;&#10;  &#34;agent_plan&#34;:&#10;    from json(&#10;      trim(&#10;        replace(&#10;          replace(&#10;            body.content[1].text,&#10;            &#34;```json&#34;,&#10;            &#34;&#34;&#10;          ),&#10;          &#34;```&#34;,&#10;          &#34;&#34;&#10;        )&#10;      )&#10;    ),&#10;&#10;  &#34;tools&#34;:&#10;    if get value(&#10;      from json(&#10;        trim(&#10;          replace(&#10;            replace(&#10;              body.content[1].text,&#10;              &#34;```json&#34;,&#10;              &#34;&#34;&#10;            ),&#10;            &#34;```&#34;,&#10;            &#34;&#34;&#10;          )&#10;        )&#10;      ),&#10;      &#34;tools&#34;&#10;    ) != null&#10;    then get value(&#10;      from json(&#10;        trim(&#10;          replace(&#10;            replace(&#10;              body.content[1].text,&#10;              &#34;```json&#34;,&#10;              &#34;&#34;&#10;            ),&#10;            &#34;```&#34;,&#10;            &#34;&#34;&#10;          )&#10;        )&#10;      ),&#10;      &#34;tools&#34;&#10;    )&#10;    else []&#10;}" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0kepnhr</bpmn:incoming>
      <bpmn:outgoing>Flow_1qc7jlo</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:adHocSubProcess id="AI_Investigation_Tools" name="AI Investigation Tools" cancelRemainingInstances="false">
      <bpmn:extensionElements>
        <zeebe:adHoc activeElementsCollection="=agent_plan.tools" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_03n63ai</bpmn:incoming>
      <bpmn:outgoing>Flow_19u3phd</bpmn:outgoing>
      <bpmn:serviceTask id="threat_intel_lookup" name="Threat Intelligence Lookup" zeebe:modelerTemplate="io.camunda.connectors.HttpJson.v2" zeebe:modelerTemplateVersion="13" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
        <bpmn:documentation>Tool: threat_intel_lookup

Description:
Prüft Indicators of Compromise (IP-Adressen, Domains oder URLs) gegen bekannte Threat-Intelligence Quellen.

Purpose:
Ermitteln, ob ein Angreifer oder eine Quelle bereits als bösartig bekannt ist.

Typical use cases:
- Netzwerkangriffe
- API Angriffe
- Brute Force Login
- Malware Kommunikation
- DDoS Angriffe

Inputs:
incident_object.short_description

Outputs:
threat_intel.threat_score
threat_intel.classification
threat_intel.source

Example result:
{
 "threat_score": 85,
 "classification": "Known botnet node",
 "source": "Threat Intelligence Feed"
}</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="io.camunda:http-json:1" retries="0" />
          <zeebe:ioMapping>
            <zeebe:input source="noAuth" target="authentication.type" />
            <zeebe:input source="GET" target="method" />
            <zeebe:input source="=&#34;https://internetdb.shodan.io/&#34; +&#10;(if incident_ip != null then incident_ip else &#34;8.8.8.8&#34;)" target="url" />
            <zeebe:input source="=false" target="storeResponse" />
            <zeebe:input source="=false" target="followRedirects" />
            <zeebe:input source="=20" target="connectionTimeoutInSeconds" />
            <zeebe:input source="=20" target="readTimeoutInSeconds" />
          </zeebe:ioMapping>
          <zeebe:taskHeaders>
            <zeebe:header key="elementTemplateVersion" value="13" />
            <zeebe:header key="elementTemplateId" value="io.camunda.connectors.HttpJson.v2" />
            <zeebe:header key="resultVariable" value="threat_intel" />
            <zeebe:header key="resultExpression" value="=if body.detail != null&#10;then {&#10;  ip: incident_ip,&#10;  ports: [],&#10;  tags: [],&#10;  vulns: []&#10;}&#10;else {&#10;  ip: body.ip,&#10;  ports: if body.ports != null then body.ports else [],&#10;  tags: if body.tags != null then body.tags else [],&#10;  vulns: if body.vulns != null then body.vulns else []&#10;}" />
            <zeebe:header key="retryBackoff" value="PT0S" />
          </zeebe:taskHeaders>
        </bpmn:extensionElements>
      </bpmn:serviceTask>
      <bpmn:scriptTask id="asset_lookup" name="Asset Infrastructure Lookup">
        <bpmn:extensionElements>
          <zeebe:script expression="={&#10;  /* ---------------- NORMALIZED INPUT ---------------- */&#10;  topic_lower:&#10;  lower case(&#10;    if sim_input != null and sim_input.incident_topic != null&#10;    then sim_input.incident_topic&#10;    else &#34;&#34;&#10;  ),&#10;&#10;  /* ---------------- ASSET EXTRACTION ---------------- */&#10;  asset_name: &#10;&#10;    /* 🔴 EXAKTE MATCHES (CASE SAFE) */&#10;    if contains(topic_lower, &#34;auth-&#34;) then&#10;      &#34;AUTH-&#34; + upper case(substring before(substring after(topic_lower, &#34;auth-&#34;), &#34; &#34;))&#10;&#10;    else if contains(topic_lower, &#34;pay-&#34;) then&#10;      &#34;PAY-&#34; + upper case(substring before(substring after(topic_lower, &#34;pay-&#34;), &#34; &#34;))&#10;&#10;    else if contains(topic_lower, &#34;db-&#34;) then&#10;      &#34;DB-&#34; + upper case(substring before(substring after(topic_lower, &#34;db-&#34;), &#34; &#34;))&#10;&#10;    else if contains(topic_lower, &#34;web-&#34;) then&#10;      &#34;WEB-&#34; + upper case(substring before(substring after(topic_lower, &#34;web-&#34;), &#34; &#34;))&#10;&#10;    else if contains(topic_lower, &#34;hr-&#34;) then&#10;      &#34;HR-&#34; + upper case(substring before(substring after(topic_lower, &#34;hr-&#34;), &#34; &#34;))&#10;&#10;    else if contains(topic_lower, &#34;data-&#34;) then&#10;      &#34;DATA-&#34; + upper case(substring before(substring after(topic_lower, &#34;data-&#34;), &#34; &#34;))&#10;&#10;    else if contains(topic_lower, &#34;fs-&#34;) then&#10;      &#34;FS-&#34; + upper case(substring before(substring after(topic_lower, &#34;fs-&#34;), &#34; &#34;))&#10;&#10;    else if contains(topic_lower, &#34;admin-&#34;) then&#10;      &#34;ADMIN-&#34; + upper case(substring before(substring after(topic_lower, &#34;admin-&#34;), &#34; &#34;))&#10;&#10;    else if contains(topic_lower, &#34;app-&#34;) then&#10;      &#34;APP-&#34; + upper case(substring before(substring after(topic_lower, &#34;app-&#34;), &#34; &#34;))&#10;&#10;    /* 🔥 FALLBACK (SEMANTISCH) */&#10;    else if contains(topic_lower, &#34;fileserver&#34;)&#10;    then &#34;FS-UNKNOWN&#34;&#10;&#10;    else if contains(topic_lower, &#34;admin&#34;)&#10;    then &#34;ADMIN-UNKNOWN&#34;&#10;&#10;    else if contains(topic_lower, &#34;application server&#34;)&#10;    then &#34;APP-UNKNOWN&#34;&#10;&#10;    else if contains(topic_lower, &#34;api&#34;)&#10;    then &#34;API-UNKNOWN&#34;&#10;&#10;    else if contains(topic_lower, &#34;kubernetes&#34;)&#10;    then &#34;K8S-NODE&#34;&#10;&#10;    /* 🔚 FINAL */&#10;    else null,&#10;&#10;  /* ---------------- ASSET DETECTION ---------------- */&#10;  asset_found: asset_name != null,&#10;&#10;  asset_type: if asset_found then &#34;Internal&#34; else &#34;External&#34;,&#10;&#10;  /* ---------------- ASSET OWNER ---------------- */&#10;  asset_owner: &#10;    if asset_name = null then &#34;Unbekannt&#34;&#10;&#10;    else if starts with(asset_name, &#34;AUTH-&#34;) then &#34;Identity Services&#34;&#10;    else if starts with(asset_name, &#34;PAY-&#34;) then &#34;Payment Platform Team&#34;&#10;    else if starts with(asset_name, &#34;DB-&#34;) then &#34;Database Operations&#34;&#10;    else if starts with(asset_name, &#34;WEB-&#34;) then &#34;Web Platform Team&#34;&#10;    else if starts with(asset_name, &#34;HR-&#34;) then &#34;HR Systems&#34;&#10;    else if starts with(asset_name, &#34;DATA-&#34;) then &#34;Data Platform Team&#34;&#10;    else if starts with(asset_name, &#34;FS-&#34;) then &#34;Storage Operations&#34;&#10;    else if starts with(asset_name, &#34;ADMIN-&#34;) then &#34;IT Administration&#34;&#10;    else if starts with(asset_name, &#34;APP-&#34;) then &#34;Application Services&#34;&#10;&#10;    else &#34;Unbekannt&#34;,&#10;&#10;  /* ---------------- ASSET CRITICALITY ---------------- */&#10;  asset_criticality: &#10;    if asset_found and (&#10;      starts with(asset_name, &#34;AUTH-&#34;) or&#10;      starts with(asset_name, &#34;PAY-&#34;) or&#10;      starts with(asset_name, &#34;DB-&#34;) or&#10;      starts with(asset_name, &#34;HR-&#34;) or&#10;      starts with(asset_name, &#34;DATA-&#34;)&#10;    ) then &#34;HIGH&#34;&#10;&#10;    else if asset_found and (&#10;      starts with(asset_name, &#34;FS-&#34;) or&#10;      starts with(asset_name, &#34;ADMIN-&#34;)&#10;    ) then &#34;HIGH&#34;&#10;&#10;    else if asset_found and (&#10;      starts with(asset_name, &#34;WEB-&#34;) or&#10;      starts with(asset_name, &#34;APP-&#34;)&#10;    ) then &#34;MEDIUM&#34;&#10;&#10;    else if asset_found then &#34;LOW&#34;&#10;&#10;    else if contains(topic_lower, &#34;kubernetes&#34;) then &#34;HIGH&#34;&#10;    else if contains(topic_lower, &#34;api&#34;) then &#34;MEDIUM&#34;&#10;&#10;    else if contains(topic_lower, &#34;ransomware&#34;) then &#34;HIGH&#34;&#10;    else if contains(topic_lower, &#34;data breach&#34;) or&#10;            contains(topic_lower, &#34;exfiltration&#34;) then &#34;HIGH&#34;&#10;&#10;    else &#34;LOW&#34;,&#10;&#10;  /* ---------------- ASSET CONFIDENCE ---------------- */&#10;  asset_confidence: &#10;&#10;    /* 🔴 EXAKT */&#10;    if asset_found &#10;       and not contains(asset_name, &#34;UNKNOWN&#34;)&#10;    then 0.95&#10;&#10;    /* 🟠 FALLBACK */&#10;    else if asset_found &#10;         and contains(asset_name, &#34;UNKNOWN&#34;)&#10;    then 0.7&#10;&#10;    /* 🟡 SEMANTIK */&#10;    else if contains(topic_lower, &#34;server&#34;)&#10;         or contains(topic_lower, &#34;api&#34;)&#10;         or contains(topic_lower, &#34;kubernetes&#34;)&#10;    then 0.6&#10;&#10;    /* ⚪ DEFAULT */&#10;    else 0.3&#10;}" resultVariable="asset_result" />
        </bpmn:extensionElements>
      </bpmn:scriptTask>
      <bpmn:serviceTask id="check_gdpr_relevance" name="check_gdpr_relevance" zeebe:modelerTemplate="io.camunda.connectors.aws.bedrock.v1" zeebe:modelerTemplateVersion="3" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
        <bpmn:documentation>Analysiert einen Sicherheitsvorfall auf DSGVO-Relevanz (PII wie Kreditkarten, IP-Adressen, User-IDs, Namen, E-Mail).
Dieses Tool wird verwendet, um das Feld "gdpr_assessment" und "is_gdpr_relevant" zu befüllen.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="io.camunda:aws-bedrock:1" retries="3" />
          <zeebe:ioMapping>
            <zeebe:input source="credentials" target="authentication.type" />
            <zeebe:input source="{{secrets.AWS_ACCESS_KEY_TW}}" target="authentication.accessKey" />
            <zeebe:input source="{{secrets.AWS_SECRET_KEY_TW}}" target="authentication.secretKey" />
            <zeebe:input source="eu-central-1" target="configuration.region" />
            <zeebe:input source="invokeModel" target="action" />
            <zeebe:input source="eu.anthropic.claude-sonnet-4-5-20250929-v1:0" target="data.modelId" />
            <zeebe:input source="={&#10;  &#34;anthropic_version&#34;: &#34;bedrock-2023-05-31&#34;,&#10;  &#34;max_tokens&#34;: 1200,&#10;  &#34;temperature&#34;: 0,&#10;  &#34;messages&#34;: [&#10;    {&#10;      &#34;role&#34;: &#34;user&#34;,&#10;      &#34;content&#34;: &#34;Du bist ein Datenschutz-Experte (DPO) und ISO 27001 Auditor.\n\nAnalysiere den folgenden Sicherheitsalarm ausschließlich anhand explizit enthaltener Informationen auf DSGVO-Relevanz gemäß Art. 4, 33 und 34 DSGVO.\n\n&#34; +&#10;&#10;      (if sim_input != null and sim_input.raw_alert != null&#10;       then sim_input.raw_alert&#10;       else if sim_input != null and sim_input.incident_topic != null&#10;       then sim_input.incident_topic&#10;       else &#34;Keine Alarm-Daten verfügbar&#34;) +&#10;&#10;      &#34;\n\nABSOLUTE VERBOTSREGEL:\n&#34; +&#10;      &#34;Keine Annahmen, Ergänzungen oder Interpretationen erzeugen.\n&#34; +&#10;      &#34;Nur explizit genannte Informationen verwenden.\n\n&#34; +&#10;&#10;      &#34;Der Incident-Input darf NICHT reproduziert oder zusammenhängend wiedergegeben werden.\n\n&#34; +&#10;&#10;      &#34;VERBOTEN:\n&#34; +&#10;      &#34;- Datenmengen schätzen\n&#34; +&#10;      &#34;- zusätzliche Datenarten ergänzen\n&#34; +&#10;      &#34;- Exfiltration annehmen\n&#34; +&#10;      &#34;- Datenverlust annehmen\n&#34; +&#10;      &#34;- Kompromittierung annehmen\n&#34; +&#10;      &#34;- Angriffserfolg interpretieren\n&#34; +&#10;      &#34;- juristische Eskalation ergänzen\n&#34; +&#10;      &#34;- Behördenmeldungen automatisch fordern\n&#34; +&#10;      &#34;- Datenschutzverletzung bestätigen\n&#34; +&#10;      &#34;- technische Schlussfolgerungen erzeugen\n\n&#34; +&#10;&#10;      &#34;WICHTIGE ENTSCHEIDUNGSREGELN:\n&#34; +&#10;      &#34;- DSGVO ist nur relevant, wenn personenbezogene Daten explizit erwähnt werden.\n&#34; +&#10;      &#34;- Wenn keine personenbezogenen Daten genannt werden: RELEVANZ = NEIN.\n&#34; +&#10;      &#34;- Reine Infrastruktur- oder Netzwerkereignisse sind keine DSGVO-Relevanz.\n\n&#34; +&#10;&#10;      &#34;RISIKO-EINSCHÄTZUNG:\n&#34; +&#10;      &#34;- LOW bei unklarem oder geringem Risiko\n&#34; +&#10;      &#34;- MEDIUM bei explizitem Zugriff auf personenbezogene Daten\n&#34; +&#10;      &#34;- HIGH nur bei explizit bestätigtem umfangreichen Datenabfluss sensitiver Daten\n\n&#34; +&#10;&#10;      &#34;MAßNAHMENREGEL:\n&#34; +&#10;      &#34;- Allgemeine Prüfmaßnahmen sind erlaubt\n&#34; +&#10;      &#34;- Formulierungen mit &#39;Prüfung&#39; oder &#39;Bewertung&#39; sind erlaubt\n&#34; +&#10;      &#34;- Keine endgültigen juristischen Feststellungen formulieren\n\n&#34; +&#10;&#10;      &#34;FORMATREGEL:\n&#34; +&#10;      &#34;- Die Ausgabe MUSS reiner Klartext sein\n&#34; +&#10;      &#34;- Kein Markdown\n&#34; +&#10;      &#34;- Keine zusätzlichen Überschriften\n\n&#34; +&#10;&#10;      &#34;Die Antwort MUSS exakt folgende Struktur verwenden:\n\n&#34; +&#10;&#10;      &#34;RELEVANZ: JA oder NEIN\n&#34; +&#10;      &#34;KATEGORIE: kurze sachliche Beschreibung oder &#39;Keine personenbezogenen Daten erkannt&#39;\n&#34; +&#10;      &#34;RISIKO-EINSCHÄTZUNG: LOW, MEDIUM oder HIGH\n&#34; +&#10;      &#34;MAßNAHME: kurze sachliche Prüfmaßnahme\n\n&#34; +&#10;&#10;      &#34;AUDIT-BEGRÜNDUNG:\n&#34; +&#10;      &#34;Nur explizit beobachtbare Fakten aus dem Incident-Input.\n\n&#34; +&#10;&#10;      &#34;REGELN FÜR DIE AUSGABE:\n&#34; +&#10;      &#34;- Keine Wiederholung des Incident-Inputs\n&#34; +&#10;      &#34;- Keine Interpretation\n&#34; +&#10;      &#34;- Keine Vermutungen\n&#34; +&#10;      &#34;- Keine zusätzlichen Daten ergänzen\n&#34; +&#10;      &#34;- Ausschließlich die finalen Bewertungsfelder ausgeben\n\n&#34; +&#10;&#10;      &#34;Antworte in einem sachlichen, defensiven Tonfall für ein Revisions-Logbuch.&#34;&#10;    }&#10;  ]&#10;}" target="data.payload" />
          </zeebe:ioMapping>
          <zeebe:taskHeaders>
            <zeebe:header key="elementTemplateVersion" value="3" />
            <zeebe:header key="elementTemplateId" value="io.camunda.connectors.aws.bedrock.v1" />
            <zeebe:header key="resultVariable" value="gdpr_raw" />
            <zeebe:header key="resultExpression" value="=response" />
            <zeebe:header key="retryBackoff" value="PT0S" />
          </zeebe:taskHeaders>
        </bpmn:extensionElements>
      </bpmn:serviceTask>
      <bpmn:completionCondition xsi:type="bpmn:tFormalExpression">=true</bpmn:completionCondition>
    </bpmn:adHocSubProcess>
    <bpmn:sequenceFlow id="Flow_19u3phd" sourceRef="AI_Investigation_Tools" targetRef="Gateway_0f83elm" />
    <bpmn:exclusiveGateway id="Gateway_05yofwt" name="Mindestens 1 Tool ausgewählt?" default="Flow_167ixj6">
      <bpmn:incoming>Flow_0fqftcs</bpmn:incoming>
      <bpmn:outgoing>Flow_03n63ai</bpmn:outgoing>
      <bpmn:outgoing>Flow_167ixj6</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_03n63ai" name="Ja" sourceRef="Gateway_05yofwt" targetRef="AI_Investigation_Tools">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=agent_plan != null 
and agent_plan.tools != null 
and count(agent_plan.tools) &gt; 0</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:exclusiveGateway id="Gateway_0f83elm">
      <bpmn:incoming>Flow_19u3phd</bpmn:incoming>
      <bpmn:incoming>Flow_167ixj6</bpmn:incoming>
      <bpmn:outgoing>Flow_1b2bwld</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_1b2bwld" sourceRef="Gateway_0f83elm" targetRef="Content_Enrichment" />
    <bpmn:sequenceFlow id="Flow_167ixj6" name="Nein" sourceRef="Gateway_05yofwt" targetRef="Gateway_0f83elm" />
    <bpmn:subProcess id="Prepare_Incident_Context" name="Prepare Incident Context">
      <bpmn:incoming>Flow_1qc7jlo</bpmn:incoming>
      <bpmn:outgoing>Flow_184d9q1</bpmn:outgoing>
      <bpmn:startEvent id="Event_0n3s93g">
        <bpmn:outgoing>Flow_07u1h65</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:endEvent id="Event_1dhtg60">
        <bpmn:extensionElements />
        <bpmn:incoming>Flow_03vegbc</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:scriptTask id="Activity_1tugk73" name="Extract Tool Plan">
        <bpmn:extensionElements>
          <zeebe:script expression="=if agent_plan.tools != null&#10;  then agent_plan.tools&#10;  else []" resultVariable="tools" />
          <zeebe:ioMapping>
            <zeebe:output source="=(now() - @&#34;1970-01-01T00:00Z&#34;) / @&#34;PT1S&#34; * 1000" target="investigation_start" />
            <zeebe:output source="=      {&#10;        dt: now(),&#10;        localDt: dt + duration(&#34;PT2H&#34;),  // Winterzeit (PT1H, MEZ = UTC+1) – im Sommer auf PT2H ändern&#10;&#10;        day:&#10;          if localDt.day &#60; 10&#10;          then &#34;0&#34; + string(localDt.day)&#10;          else string(localDt.day),&#10;&#10;        month:&#10;          substring(month of year(localDt), 1, 3),&#10;&#10;        year:&#10;          string(localDt.year),&#10;&#10;        hour:&#10;          if localDt.hour &#60; 10&#10;          then &#34;0&#34; + string(localDt.hour)&#10;          else string(localDt.hour),&#10;&#10;        minute:&#10;          if localDt.minute &#60; 10&#10;          then &#34;0&#34; + string(localDt.minute)&#10;          else string(localDt.minute),&#10;&#10;        second:&#10;          if localDt.second &#60; 10&#10;          then &#34;0&#34; + string(localDt.second)&#10;          else string(localDt.second),&#10;&#10;        formatted:&#10;          day + &#34;.&#34; + month + &#34; &#34; + year + &#34; &#34; +&#10;          hour + &#34;:&#34; + minute + &#34;:&#34; + second&#10;      }.formatted" target="creation_time" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_07u1h65</bpmn:incoming>
        <bpmn:outgoing>Flow_1fpayh6</bpmn:outgoing>
      </bpmn:scriptTask>
      <bpmn:scriptTask id="Activity_0kmtlah" name="DEBUG">
        <bpmn:extensionElements>
          <zeebe:script expression="=if tools = null&#10;then &#34;TOOLS = NULL&#34;&#10;else if count(tools) = 0&#10;then &#34;TOOLS = [] (keine Tools geplant)&#34;&#10;else &#34;TOOLS = &#34; + string join(tools,&#34;, &#34;)" resultVariable="used_tools" />
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_1fpayh6</bpmn:incoming>
        <bpmn:outgoing>Flow_056qd13</bpmn:outgoing>
      </bpmn:scriptTask>
      <bpmn:scriptTask id="Extract_Reports" name="Extract Reports">
        <bpmn:extensionElements>
          <zeebe:script expression="={&#10;  iso_report:&#10;    if iso_raw != null&#10;    then iso_raw.body.content[1].text&#10;    else null,&#10;&#10;  gdpr_result:&#10;    if gdpr_raw != null&#10;    then {&#10;      text: gdpr_raw.body.content[1].text,&#10;      is_relevant:&#10;        contains(&#10;          lower case(gdpr_raw.body.content[1].text),&#10;          &#34;relevanz: ja&#34;&#10;        )&#10;    }&#10;    else null&#10;}" resultVariable="ai_extract" />
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_0zaatrx</bpmn:incoming>
        <bpmn:outgoing>Flow_0sy75xp</bpmn:outgoing>
      </bpmn:scriptTask>
      <bpmn:serviceTask id="write_iso_report" name="write_iso_report" zeebe:modelerTemplate="io.camunda.connectors.aws.bedrock.v1" zeebe:modelerTemplateVersion="3" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
        <bpmn:documentation>Dieses Werkzeug erstellt einen detaillierten ISO 27001 Fachbericht für einen Sicherheitsvorfall. Es analysiert technische Alarme, ordnet sie den passenden Annex A Controls zu und gibt technische Handlungsempfehlungen. Dieses Tool muss zwingend aufgerufen werden, um die Sektion 'final_report' für ServiceNow zu befüllen.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="io.camunda:aws-bedrock:1" retries="3" />
          <zeebe:ioMapping>
            <zeebe:input source="credentials" target="authentication.type" />
            <zeebe:input source="{{secrets.AWS_ACCESS_KEY_TW}}" target="authentication.accessKey" />
            <zeebe:input source="{{secrets.AWS_SECRET_KEY_TW}}" target="authentication.secretKey" />
            <zeebe:input source="eu-central-1" target="configuration.region" />
            <zeebe:input source="invokeModel" target="action" />
            <zeebe:input source="eu.anthropic.claude-sonnet-4-5-20250929-v1:0" target="data.modelId" />
            <zeebe:input source="={&#10;  &#34;anthropic_version&#34;: &#34;bedrock-2023-05-31&#34;,&#10;  &#34;max_tokens&#34;: 2200,&#10;  &#34;temperature&#34;: 0,&#10;  &#34;messages&#34;: [&#10;    {&#10;      &#34;role&#34;: &#34;user&#34;,&#10;      &#34;content&#34;: &#34;Du bist ein ISO 27001 Auditor.\n      \nWICHTIGE KONTEXTREGELN:\nEs ist streng verboten, technische Details zu ergänzen, die nicht explizit im Incident-Input genannt werden.\n\nWenn der Vorfall als geplanter, interner oder autorisierter Sicherheitsscan beschrieben wird:\n\n- Klassifiziere den Vorfall als legitime Aktivität\n- Verwende KEINE Formulierungen wie:\n  \&#34;Kompromittierung\&#34;, \&#34;Angriff\&#34;, \&#34;Bedrohung\&#34;\n- Formuliere neutral und sachlich\n- Stelle klar, daß kein Sicherheitsvorfall vorliegt\n\nWenn die Aktivität auf reguläre Systemprozesse zurückzuführen ist:\n\n- Klassifiziere die Aktivität als regulären Betriebsprozess\n- Stelle klar, daß kein Sicherheitsvorfall vorliegt\n- Verwende KEINE übermäßige Eskalation\n\nWICHTIG:\nWenn Informationen nicht explizit im Input stehen:\n→ NICHT erwähnen.\n\nKeine:\n- Interpretation\n- Ursache-Wirkung\n- Plausibilitätsannahmen\n- Angriffserfolg\n- Risikoanalyse\n- Sicherheitsbewertung\n- forensischen Schlussfolgerungen\n- technischen Ergänzungen\n\nInsbesondere KEINE:\n- Benutzerkennungen\n- Dateinamen\n- Hostnamen\n- Prozesse\n- Ports\n- Malware\n- IP-Adressen\n- Datenmengen\n- Infrastrukturdetails\n- organisatorischen Zusammenhänge\n\nNutze ausschließlich Informationen aus dem Incident-Input.\n\nFORMATREGEL:\nDie Ausgabe MUSS reiner Klartext sein.\n\nVERBOTEN:\n- Markdown\n- JSON\n- Tabellen\n- zusätzliche Überschriften\n- Markdown-Symbole\n\nErstelle eine professionelle Beweisanalyse für den folgenden Sicherheitsalarm: \n\n&#34; + &#10;(if sim_input != null and sim_input.raw_alert != null &#10;   then sim_input.raw_alert &#10;   else &#34;Keine Alarm-Daten verfügbar&#34;) + &#10;&#34;\n\nSTRUKTUR DES BERICHTS:\n\n1. VORFALL:\nBeschreibe den Vorfall kurz und technisch präzise.\n\nREGELN:\n- maximal 2 kurze Sätze\n- keine Spekulationen\n- nur beobachtbare Ereignisse beschreiben\n- nichts ergänzen oder interpretieren\n\n2. UMGEHEND AUSFÜHREN:\nKurze technische Maßnahmen als Bullet-Liste.\nWenn kein sicherheitsrelevanter Vorfall vorliegt:\n- nur informative Maßnahmen\n- keine Eskalation\n\n3. ISO 27001 MAPPING:\nWähle nur tatsächlich relevante ISO 27001 Controls.\n\nREGELN:\n- typischerweise 3 bis 6 Controls\n- kurze deutsche Bezeichnungen\n- keine generischen Fallback-Controls\n- keine Statusbewertungen\n- immer nummerierte Liste\n\nWICHTIG:\n- Verwende die Überschriften exakt und unverändert:\n  \&#34;1. VORFALL:\&#34;\n  \&#34;2. UMGEHEND AUSFÜHREN:\&#34;\n  \&#34;3. ISO 27001 MAPPING:\&#34;\n- Keine zusätzlichen Abschnitte erzeugen\n- Nach Abschnitt 3 MUSS exakt \&#34;---\&#34; folgen\n- Keine Einleitung oder Schlussformulierung hinzufügen\n\nAntworte in einem sachlichen, präzisen Tonfall für ein Audit-Logbuch. Antworte als reiner Text, kein JSON.&#34;&#10;    }&#10;  ]&#10;}" target="data.payload" />
          </zeebe:ioMapping>
          <zeebe:taskHeaders>
            <zeebe:header key="elementTemplateVersion" value="3" />
            <zeebe:header key="elementTemplateId" value="io.camunda.connectors.aws.bedrock.v1" />
            <zeebe:header key="resultVariable" value="iso_raw" />
            <zeebe:header key="resultExpression" value="=response" />
            <zeebe:header key="retryBackoff" value="PT0S" />
          </zeebe:taskHeaders>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_056qd13</bpmn:incoming>
        <bpmn:outgoing>Flow_1q1cerp</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:scriptTask id="Activity_1uiy774" name="Extract Incident IP">
        <bpmn:extensionElements>
          <zeebe:script expression="=if ioc_results.ips[1] != null &#10;then ioc_results.ips[1] &#10;else &#34;Unbekannt&#34;" resultVariable="incident_ip" />
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_1j22t3k</bpmn:incoming>
        <bpmn:outgoing>Flow_1e2dmpo</bpmn:outgoing>
      </bpmn:scriptTask>
      <bpmn:scriptTask id="Find_IP_in_Topic" name="Find IP in Topic">
        <bpmn:extensionElements>
          <zeebe:script expression="={&#10;  ips: flatten(for word in split(sim_input.incident_topic, &#34; &#34;) return if matches(word, &#34;^(\\d{1,3}\\.){3}\\d{1,3}$&#34;) then word else []),&#10;  domains: flatten(for word in split(sim_input.incident_topic, &#34; &#34;) return if matches(word, &#34;^([a-z0-9]+(-[a-z0-9]+)*\\.)+[a-z]{2,}$&#34;) then word else []),&#10;  hashes: flatten(for word in split(sim_input.incident_topic, &#34; &#34;) return if matches(word, &#34;^[a-fA-F0-9]{32}$|^[a-fA-F0-9]{64}$&#34;) then word else [])&#10;}" resultVariable="ioc_results" />
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_0sy75xp</bpmn:incoming>
        <bpmn:outgoing>Flow_1j22t3k</bpmn:outgoing>
      </bpmn:scriptTask>
      <bpmn:scriptTask id="Pre_Incident_Builder" name="Pre Incident Builder">
        <bpmn:extensionElements>
          <zeebe:script expression="={&#10;  topic:&#10;    lower case(&#10;      if sim_input != null and sim_input.incident_topic != null&#10;      then sim_input.incident_topic&#10;      else &#34;&#34;&#10;    ),&#10;&#10;  incident_ip:&#10;    if incident_ip != null and incident_ip != &#34;&#34;&#10;    then incident_ip&#10;    else null,&#10;&#10;  threat_score: 0,&#10;&#10;  threat_tags_string: &#34;&#34;,&#10;&#10;  threat_ports_string: &#34;&#34;,&#10;&#10;  threat_services_string: &#34;&#34;,&#10;&#10;  asset_criticality:&#10;    if asset_result != null and asset_result.asset_criticality != null&#10;    then asset_result.asset_criticality&#10;    else &#34;Unbekannt&#34;,&#10;&#10;  is_gdpr_relevant:&#10;    if gdpr_raw != null&#10;       and gdpr_raw.body != null&#10;       and gdpr_raw.body.content != null&#10;       and count(gdpr_raw.body.content) &#62; 0&#10;    then contains(lower case(gdpr_raw.body.content[1].text), &#34;relevanz: ja&#34;)&#10;    else false&#10;}" resultVariable="pre_incident_object" />
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_1e2dmpo</bpmn:incoming>
        <bpmn:outgoing>Flow_03vegbc</bpmn:outgoing>
      </bpmn:scriptTask>
      <bpmn:sequenceFlow id="Flow_1fpayh6" sourceRef="Activity_1tugk73" targetRef="Activity_0kmtlah" />
      <bpmn:sequenceFlow id="Flow_056qd13" sourceRef="Activity_0kmtlah" targetRef="write_iso_report" />
      <bpmn:sequenceFlow id="Flow_1q1cerp" sourceRef="write_iso_report" targetRef="Extract_ISO_Text" />
      <bpmn:sequenceFlow id="Flow_0sy75xp" sourceRef="Extract_Reports" targetRef="Find_IP_in_Topic" />
      <bpmn:sequenceFlow id="Flow_1j22t3k" sourceRef="Find_IP_in_Topic" targetRef="Activity_1uiy774" />
      <bpmn:sequenceFlow id="Flow_1e2dmpo" sourceRef="Activity_1uiy774" targetRef="Pre_Incident_Builder" />
      <bpmn:sequenceFlow id="Flow_07u1h65" sourceRef="Event_0n3s93g" targetRef="Activity_1tugk73" />
      <bpmn:sequenceFlow id="Flow_03vegbc" sourceRef="Pre_Incident_Builder" targetRef="Event_1dhtg60" />
      <bpmn:sequenceFlow id="Flow_1gogfkf" sourceRef="Extract_ISO_Text" targetRef="Extract_ISO_Mapping" />
      <bpmn:scriptTask id="Extract_ISO_Text" name="Extract ISO Text">
        <bpmn:extensionElements>
          <zeebe:script expression="=if iso_raw.body.content[1].text != null&#10;then iso_raw.body.content[1].text&#10;else iso_raw.body.content[0].text" resultVariable="iso_text" />
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_1q1cerp</bpmn:incoming>
        <bpmn:outgoing>Flow_1gogfkf</bpmn:outgoing>
      </bpmn:scriptTask>
      <bpmn:sequenceFlow id="Flow_1oxssyk" sourceRef="Extract_ISO_Mapping" targetRef="Extract_ISO_Controls" />
      <bpmn:scriptTask id="Extract_ISO_Mapping" name="Extract ISO Mapping">
        <bpmn:extensionElements>
          <zeebe:script expression="=substring before(&#10;  substring after(iso_text, &#34;3. ISO 27001 MAPPING:&#34;),&#10;  &#34;---&#34;&#10;)" resultVariable="iso_mapping" />
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_1gogfkf</bpmn:incoming>
        <bpmn:outgoing>Flow_1oxssyk</bpmn:outgoing>
      </bpmn:scriptTask>
      <bpmn:sequenceFlow id="Flow_0zaatrx" sourceRef="Extract_ISO_Controls" targetRef="Extract_Reports" />
      <bpmn:scriptTask id="Extract_ISO_Controls" name="Extract ISO Controls">
        <bpmn:extensionElements>
          <zeebe:script expression="=flatten(&#10;  for line in split(iso_mapping, &#34;\n&#34;) return&#10;    if line != &#34;&#34; and contains(line, &#34;A.&#34;)&#10;    then [{&#10;      text: substring after(line, &#34;. &#34;),&#10;      status: &#34;PENDING&#34;&#10;    }]&#10;    else []&#10;)" resultVariable="iso_controls" />
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_1oxssyk</bpmn:incoming>
        <bpmn:outgoing>Flow_0zaatrx</bpmn:outgoing>
      </bpmn:scriptTask>
    </bpmn:subProcess>
    <bpmn:sequenceFlow id="Flow_184d9q1" sourceRef="Prepare_Incident_Context" targetRef="Activity_0w8ynwr" />
    <bpmn:subProcess id="Activity_0w8ynwr" name="Analyze Threat (AI)">
      <bpmn:incoming>Flow_184d9q1</bpmn:incoming>
      <bpmn:outgoing>Flow_0fqftcs</bpmn:outgoing>
      <bpmn:serviceTask id="Threat_Interpretation_AI" name="Threat Interpretation AI" zeebe:modelerTemplate="io.camunda.connectors.aws.bedrock.v1" zeebe:modelerTemplateVersion="3" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
        <bpmn:documentation>🧠 WAS HIER PASSIERT

Das Modell wird gezwungen zu:

Struktur ✅

Disziplin ✅

Wiederholbarkeit ✅

👉 Und ganz wichtig:

❗ Das Modell entscheidet NICHT die Action

⚠️ HÄUFIGER FEHLER (VERMEIDEN)

Nicht machen:

„Analysiere bitte…“
„Was denkst du…“

👉 Das führt zu:
❌ Fließtext
❌ inkonsistente Antworten</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="io.camunda:aws-bedrock:1" retries="3" />
          <zeebe:ioMapping>
            <zeebe:input source="credentials" target="authentication.type" />
            <zeebe:input source="{{secrets.AWS_ACCESS_KEY_TW}}" target="authentication.accessKey" />
            <zeebe:input source="{{secrets.AWS_SECRET_KEY_TW}}" target="authentication.secretKey" />
            <zeebe:input source="eu-central-1" target="configuration.region" />
            <zeebe:input source="invokeModel" target="action" />
            <zeebe:input source="eu.anthropic.claude-sonnet-4-5-20250929-v1:0" target="data.modelId" />
            <zeebe:input source="={&#10;  &#34;anthropic_version&#34;: &#34;bedrock-2023-05-31&#34;,&#10;  &#34;max_tokens&#34;: 400,&#10;  &#34;temperature&#34;: 0,  &#10;  &#34;messages&#34;: [&#10;    {&#10;      &#34;role&#34;: &#34;user&#34;,&#10;      &#34;content&#34;: &#10;        &#34;Du bist eine SOC-Analyse-Engine für Sicherheitsvorfälle.\n\n&#34;&#10;        + &#34;Analysiere den folgenden Vorfall technisch und klassifiziere ihn strukturiert.\n\n&#34;&#10;        + &#34;VORFALLSDATEN:\n\n&#34;&#10;        + &#34;Topic: &#34; + (if pre_incident_object.topic != null then pre_incident_object.topic else &#34;unbekannt&#34;) + &#34;\n&#34;&#10;        + &#34;IP Adresse: &#34; + (if pre_incident_object.incident_ip != null then pre_incident_object.incident_ip else &#34;unbekannt&#34;) + &#34;\n&#34;&#10;        + &#34;Threat Score: &#34; + (if pre_incident_object.threat_score != null then string(pre_incident_object.threat_score) else &#34;0&#34;) + &#34;\n&#34;&#10;        + &#34;Tags: &#34; + (if pre_incident_object.threat_tags_string != null then pre_incident_object.threat_tags_string else &#34;&#34;) + &#34;\n&#34;&#10;        + &#34;Ports: &#34; + (if pre_incident_object.threat_ports_string != null then pre_incident_object.threat_ports_string else &#34;&#34;) + &#34;\n&#34;&#10;        + &#34;Services: &#34; + (if pre_incident_object.threat_services_string != null then pre_incident_object.threat_services_string else &#34;&#34;) + &#34;\n&#34;&#10;        + &#34;Asset Kritikalität: &#34; + (if pre_incident_object.asset_criticality != null then pre_incident_object.asset_criticality else &#34;unbekannt&#34;) + &#34;\n&#34;&#10;        + &#34;GDPR relevant: &#34; + (if pre_incident_object.is_gdpr_relevant != null then string(pre_incident_object.is_gdpr_relevant) else &#34;false&#34;) + &#34;\n\n&#34;&#10;        + &#34;AUFGABE:\n&#34;&#10;        + &#34;Klassifiziere den Vorfall technisch. Berücksichtige dabei auch Formulierungen wie \&#34;Es wurde eine ungewöhnliche Verarbeitung und Speicherung...\&#34;, \&#34;Ungewöhnliche Aktivität erkannt...\&#34;, \&#34;Auffällige Zugriffe...\&#34; oder ähnliche Hinweise auf Anomalien.\n\n&#34;&#10;        + &#34;AUSGABEFORMAT (exakt einhalten – nur gültiges JSON):\n\n&#34;&#10;        + &#34;{\n&#34;&#10;        + &#34;  \&#34;threat_type\&#34;: \&#34;botnet_c2 | malware | credential_theft | data_exfiltration | scanning | lateral_movement | privilege_escalation | persistence | data_staging | phishing | ddos | insider_threat | anomalous_behavior | benign | unknown\&#34;,\n&#34;&#10;        + &#34;  \&#34;attack_stage\&#34;: \&#34;reconnaissance | initial_access | execution | persistence | command_and_control | exfiltration | unknown\&#34;,\n&#34;&#10;        + &#34;  \&#34;intent\&#34;: \&#34;malicious | suspicious | benign | unknown\&#34;,\n&#34;&#10;        + &#34;  \&#34;impact_hint\&#34;: \&#34;high | medium | low\&#34;,\n&#34;&#10;        + &#34;  \&#34;urgency_hint\&#34;: \&#34;high | medium | low\&#34;,\n&#34;&#10;        + &#34;  \&#34;confidence\&#34;: 0.0,\n&#34;&#10;        + &#34;  \&#34;explanation\&#34;: \&#34;kurze technische Begründung\&#34;\n&#34;&#10;        + &#34;}\n\n&#34;&#10;        + &#34;REGELN (streng befolgen):\n&#34;&#10;        + &#34;- Antworte ausschließlich mit dem JSON-Objekt – kein zusätzlicher Text, keine Markdown, keine Erklärungen außerhalb des JSON.\n&#34;&#10;        + &#34;- Berücksichtige Hinweise auf ungewöhnliche Verarbeitung, Speicherung, Zugriffe oder Anomalien (z. B. \&#34;ungewöhnliche Verarbeitung\&#34;, \&#34;auffällige Aktivität\&#34;, \&#34;verdächtige Speicherung\&#34;).\n&#34;&#10;        + &#34;- Bei vertrauenswürdiger Infrastruktur (Google 8.8.8.8, Cloudflare 1.1.1.1, AWS, Azure, Akamai, Fastly, große CDNs etc.):\n&#34;&#10;        + &#34;  → Klassifiziere als \&#34;benign\&#34; und \&#34;erwartbares Netzwerkverhalten\&#34;.\n&#34;&#10;        + &#34;  → Verwende KEINE Begriffe wie Angriff, Kompromittierung, Bedrohung oder kritischer Vorfall.\n&#34;&#10;        + &#34;- Bei TOR-Exit-Nodes oder Anonymisierungsdiensten: \&#34;intent\&#34; = \&#34;suspicious\&#34; und entsprechende Untersuchungsempfehlung in der explanation.\n&#34;&#10;        + &#34;- confidence-Wert zwischen 0.0 und 1.0 (realistisch einschätzen).\n&#34;&#10;        + &#34;- Erkläre in \&#34;explanation\&#34; kurz und technisch, warum du die Klassifikation gewählt hast.&#34;&#10;    }&#10;  ]&#10;}" target="data.payload" />
          </zeebe:ioMapping>
          <zeebe:taskHeaders>
            <zeebe:header key="elementTemplateVersion" value="3" />
            <zeebe:header key="elementTemplateId" value="io.camunda.connectors.aws.bedrock.v1" />
            <zeebe:header key="resultVariable" value="llm_raw_output" />
            <zeebe:header key="retryBackoff" value="PT0S" />
          </zeebe:taskHeaders>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_1xh5snp</bpmn:incoming>
        <bpmn:outgoing>Flow_1j4m7vi</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:scriptTask id="Parse_Threat_AI_Analysis" name="Parse Threat AI Analysis">
        <bpmn:extensionElements>
          <zeebe:script expression="={&#10;  raw_text: &#10;    if llm_raw_output != null &#10;       and llm_raw_output.body != null &#10;       and llm_raw_output.body.content != null &#10;       and count(llm_raw_output.body.content) &#62; 0 &#10;       and llm_raw_output.body.content[1] != null&#10;       and llm_raw_output.body.content[1].text != null&#10;    then llm_raw_output.body.content[1].text&#10;    else null,&#10;&#10;  /* ================= MANUELLE FELD-EXTRAKTION ================= */&#10;&#10;  llm_threat_type:&#10;    if raw_text != null&#10;    then lower case(trim(substring before(substring after(raw_text, &#34;\&#34;threat_type\&#34;: \&#34;&#34;), &#34;\&#34;&#34;)))&#10;    else null,&#10;&#10;  llm_attack_stage:&#10;    if raw_text != null&#10;    then lower case(trim(substring before(substring after(raw_text, &#34;\&#34;attack_stage\&#34;: \&#34;&#34;), &#34;\&#34;&#34;)))&#10;    else null,&#10;&#10;  llm_intent:&#10;    if raw_text != null&#10;    then lower case(trim(substring before(substring after(raw_text, &#34;\&#34;intent\&#34;: \&#34;&#34;), &#34;\&#34;&#34;)))&#10;    else null,&#10;&#10;  llm_impact_hint:&#10;    if raw_text != null&#10;    then lower case(trim(substring before(substring after(raw_text, &#34;\&#34;impact_hint\&#34;: \&#34;&#34;), &#34;\&#34;&#34;)))&#10;    else &#34;low&#34;,&#10;&#10;  llm_urgency_hint:&#10;    if raw_text != null&#10;    then lower case(trim(substring before(substring after(raw_text, &#34;\&#34;urgency_hint\&#34;: \&#34;&#34;), &#34;\&#34;&#34;)))&#10;    else &#34;low&#34;,&#10;&#10;  llm_confidence:&#10;    if raw_text != null&#10;    then number(trim(substring before(substring after(raw_text, &#34;\&#34;confidence\&#34;: &#34;), &#34;,&#34;)))&#10;    else 0.5,&#10;&#10;  llm_explanation:&#10;    if raw_text != null&#10;    then trim(substring before(substring after(raw_text, &#34;\&#34;explanation\&#34;: \&#34;&#34;), &#34;\&#34;&#34;))&#10;    else &#34;Keine Begründung vorhanden&#34;,&#10;&#10;  /* Debug */&#10;  parse_success: true,&#10;  raw_text_preview: if raw_text != null then substring(raw_text, 1, 300) else null&#10;}" resultVariable="llm_analysis" />
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_1j4m7vi</bpmn:incoming>
        <bpmn:outgoing>Flow_0xm84ex</bpmn:outgoing>
      </bpmn:scriptTask>
      <bpmn:scriptTask id="Activity_0knsst7" name="Agent Plan Normalizer">
        <bpmn:extensionElements>
          <zeebe:script expression="={&#10;tools:&#10;&#10;  if agent_plan = null&#10;     or agent_plan.tools = null&#10;     or count(agent_plan.tools) = 0&#10;  then&#10;&#10;    /* 🔥 INTELLIGENTER FALLBACK */&#10;&#10;    if incident_ip != null&#10;       and incident_ip != &#34;&#34;&#10;       and incident_ip != &#34;Unbekannt&#34;&#10;    then [&#34;threat_intel_lookup&#34;]&#10;&#10;    else []&#10;&#10;  else&#10;&#10;    (&#10;      for t in agent_plan.tools&#10;      return&#10;&#10;        /* 🔴 Threat Intel nur mit IP */&#10;        if t = &#34;threat_intel_lookup&#34;&#10;           and not(&#10;             incident_ip != null&#10;             and incident_ip != &#34;&#34;&#10;             and incident_ip != &#34;Unbekannt&#34;&#10;           )&#10;        then null&#10;&#10;        /* 🔴 Asset Lookup nur bei asset_hint */&#10;	   else if t = &#34;asset_lookup&#34;&#10;	     and asset_detection.asset_hint = null&#10;	     and not(contains(topic, &#34;-&#34;))&#10;	   then null&#10;        &#10;          &#10;                    &#10;        else t&#10;    )[item != null]&#10;}" resultVariable="agent_plan" />
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_0dn6uic</bpmn:incoming>
        <bpmn:outgoing>Analyze_Threat_AI</bpmn:outgoing>
      </bpmn:scriptTask>
      <bpmn:sequenceFlow id="Flow_1j4m7vi" sourceRef="Threat_Interpretation_AI" targetRef="Parse_Threat_AI_Analysis" />
      <bpmn:sequenceFlow id="Flow_0xm84ex" sourceRef="Parse_Threat_AI_Analysis" targetRef="Activity_1mmn11d" />
      <bpmn:startEvent id="Event_0z0owd2">
        <bpmn:outgoing>Flow_1xh5snp</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:sequenceFlow id="Flow_1xh5snp" sourceRef="Event_0z0owd2" targetRef="Threat_Interpretation_AI" />
      <bpmn:endEvent id="Event_1h9txkw">
        <bpmn:incoming>Analyze_Threat_AI</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Analyze_Threat_AI" name="Analyze Threat (AI)" sourceRef="Activity_0knsst7" targetRef="Event_1h9txkw" />
      <bpmn:sequenceFlow id="Flow_0dn6uic" sourceRef="Mini_Asset_Detection" targetRef="Activity_0knsst7" />
      <bpmn:scriptTask id="Mini_Asset_Detection" name="Mini Asset Detection">
        <bpmn:extensionElements>
          <zeebe:script expression="={&#10;  asset_hint:&#10;&#10;    if contains(lower case(sim_input.incident_topic), &#34;crm-prod-&#34;)&#10;    then &#34;CRM-PROD-02&#34;&#10;&#10;    else if contains(lower case(sim_input.incident_topic), &#34;db-prod-&#34;)&#10;    then &#34;DB-PROD-02&#34;&#10;&#10;    else if contains(lower case(sim_input.incident_topic), &#34;auth-01&#34;)&#10;    then &#34;AUTH-01&#34;&#10;&#10;    else null&#10;}" resultVariable="asset_detection" />
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_1nka4il</bpmn:incoming>
        <bpmn:outgoing>Flow_0dn6uic</bpmn:outgoing>
      </bpmn:scriptTask>
      <bpmn:sequenceFlow id="Flow_03y4swm" sourceRef="Short_Description_AI" targetRef="llm_explanation_AI" />
      <bpmn:serviceTask id="Short_Description_AI" name="Short_Description AI" zeebe:modelerTemplate="io.camunda.connectors.aws.bedrock.v1" zeebe:modelerTemplateVersion="3" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="io.camunda:aws-bedrock:1" retries="3" />
          <zeebe:ioMapping>
            <zeebe:input source="credentials" target="authentication.type" />
            <zeebe:input source="{{secrets.AWS_ACCESS_KEY_TW}}" target="authentication.accessKey" />
            <zeebe:input source="{{secrets.AWS_SECRET_KEY_TW}}" target="authentication.secretKey" />
            <zeebe:input source="eu-central-1" target="configuration.region" />
            <zeebe:input source="invokeModel" target="action" />
            <zeebe:input source="eu.anthropic.claude-sonnet-4-5-20250929-v1:0" target="data.modelId" />
            <zeebe:input source="={&#10;  &#34;anthropic_version&#34;: &#34;bedrock-2023-05-31&#34;,&#10;  &#34;max_tokens&#34;: 80,&#10;  &#34;temperature&#34;: 0,  &#10;  &#34;messages&#34;: [&#10;    {&#10;      &#34;role&#34;: &#34;user&#34;,&#10;      &#34;content&#34;: &#10;        &#34;Du bist ein erfahrener SOC-Analyst.\n\n&#34;&#10;        + &#34;AUFGABE:\n&#34;&#10;        + &#34;Erstelle eine extrem kurze Incident-Beschreibung für ein ServiceNow-Ticket.\n\n&#34;&#10;        + &#34;INPUT:\n&#34;&#10;        + (if sim_input != null and sim_input.incident_topic != null &#10;           then string(sim_input.incident_topic) &#10;           else &#34;kein Incident Text verfügbar&#34;)&#10;        + &#34;\n\n&#34;&#10;        + &#34;REGELN (streng einhalten):\n&#34;&#10;        + &#34;- Der Angriffstyp muss immer am Anfang stehen (höchste Priorität)\n&#34;&#10;        + &#34;- Danach das betroffene Asset oder Ziel nennen (falls erkennbar)\n&#34;&#10;        + &#34;- Maximal 8 Wörter insgesamt\n&#34;&#10;        + &#34;- Nur relevante Fachbegriffe verwenden\n&#34;&#10;        + &#34;- Keine Risikobewertung (kein kritisch, hoch, dringend etc.)\n&#34;&#10;        + &#34;- Keine Füllwörter und keine Floskeln\n&#34;&#10;        + &#34;- Keine Satzzeichen am Ende\n&#34;&#10;        + &#34;- Ausgabe ausschließlich auf Deutsch\n\n&#34;&#10;        + &#34;FORMAT (STRICT):\n&#34;&#10;        + &#34;Antworte ausschließlich mit folgendem gültigen JSON. Kein zusätzlicher Text.\n\n&#34;&#10;        + &#34;{\&#34;short_description\&#34;: \&#34;Angriffstyp [auf/bei/gegen] Asset\&#34;}\n\n&#34;&#10;        + &#34;Beispiele:\n&#34;&#10;        + &#34;{\&#34;short_description\&#34;: \&#34;SSH Brute Force auf ADMIN-01\&#34;}\n&#34;&#10;        + &#34;{\&#34;short_description\&#34;: \&#34;DDoS Angriff auf Bank-Webseite\&#34;}\n&#34;&#10;        + &#34;{\&#34;short_description\&#34;: \&#34;Brute Force gegen OpenSSH Server\&#34;}\n&#34;&#10;        + &#34;{\&#34;short_description\&#34;: \&#34;Malware Infektion auf PC-47291\&#34;}\n\n&#34;&#10;        + &#34;WICHTIG: Der Angriffstyp steht immer als erstes Wort bzw. erste Wortgruppe.&#34;&#10;    }&#10;  ]&#10;}" target="data.payload" />
          </zeebe:ioMapping>
          <zeebe:taskHeaders>
            <zeebe:header key="elementTemplateVersion" value="3" />
            <zeebe:header key="elementTemplateId" value="io.camunda.connectors.aws.bedrock.v1" />
            <zeebe:header key="resultVariable" value="short_description_raw" />
            <zeebe:header key="resultExpression" value="=from json(&#10;  trim(&#10;    replace(&#10;      replace(&#10;        body.content[1].text,&#10;        &#34;```json&#34;,&#10;        &#34;&#34;&#10;      ),&#10;      &#34;```&#34;,&#10;      &#34;&#34;&#10;    )&#10;  )&#10;)" />
            <zeebe:header key="retryBackoff" value="PT0S" />
          </zeebe:taskHeaders>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_0hxjfpm</bpmn:incoming>
        <bpmn:outgoing>Flow_03y4swm</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="llm_explanation_AI" name="llm_explanation AI" zeebe:modelerTemplate="io.camunda.connectors.aws.bedrock.v1" zeebe:modelerTemplateVersion="3" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="io.camunda:aws-bedrock:1" retries="3" />
          <zeebe:ioMapping>
            <zeebe:input source="credentials" target="authentication.type" />
            <zeebe:input source="{{secrets.AWS_ACCESS_KEY_TW}}" target="authentication.accessKey" />
            <zeebe:input source="{{secrets.AWS_SECRET_KEY_TW}}" target="authentication.secretKey" />
            <zeebe:input source="eu-central-1" target="configuration.region" />
            <zeebe:input source="invokeModel" target="action" />
            <zeebe:input source="eu.anthropic.claude-sonnet-4-5-20250929-v1:0" target="data.modelId" />
            <zeebe:input source="={&#10;  &#34;anthropic_version&#34;: &#34;bedrock-2023-05-31&#34;,&#10;  &#34;max_tokens&#34;: 150,&#10;  &#34;temperature&#34;: 0,  &#10;  &#34;messages&#34;: [&#10;    {&#10;      &#34;role&#34;: &#34;user&#34;,&#10;      &#34;content&#34;: &#34;Du bist ein extrem disziplinierter SOC-Analyst. Deine einzige Aufgabe ist es, eine **sehr kurze, nüchterne Risikoaussage** im reinen SOC-Stil zu erstellen.\n\n&#34; +&#10;&#10;        &#34;HÖCHSTE PRIORITÄT – BEACHTE UNBEDINGT:\n&#34; +&#10;        &#34;is_real_incident: &#34; + string(detect_real_incident_result.is_real_incident) + &#34;\n\n&#34; +&#10;&#10;        &#34;BEDEUTUNG (absolute Priorität):\n&#34; +&#10;        &#34;- false → Die Aktivität ist wahrscheinlich benign, erwartet oder legitim. Formuliere **neutral bis entlastend**, ohne jede Andeutung von Gefahr oder Risiko. Verwende Begriffe wie \&#34;erwartbar\&#34;, \&#34;legitim\&#34;, \&#34;planmäßig\&#34;, \&#34;im Rahmen üblicher Aktivitäten\&#34;.\n&#34; +&#10;        &#34;- true → Formuliere eine klare, faktenbasierte Risikoaussage mit möglichem Angriffsbezug. &#10;        Benenne das wahrscheinlichste Szenario (z. B. Brute-Force, Credential Stuffing, Reconnaissance), &#10;        ohne zu dramatisieren, aber mit klarer sicherheitstechnischer Einordnung. &#10;        - Bei realen Vorfällen soll die Aussage eine implizite Handlungsempfehlung enthalten (z. B. Untersuchung empfohlen, weitere Analyse erforderlich)\n\n&#34; +&#10;&#10;        &#34;EINGABEDATEN:\n&#34; +&#10;        &#34;Erklärung: &#34; + (if llm_analysis.llm_explanation != null then llm_analysis.llm_explanation else &#34;keine Erklärung verfügbar&#34;) + &#34;\n&#34; +&#10;        &#34;Angriffstyp: &#34; + (if llm_analysis.llm_threat_type != null then llm_analysis.llm_threat_type else &#34;unbekannt&#34;) + &#34;\n&#34; +&#10;        &#34;Phase: &#34; + (if llm_analysis.llm_attack_stage != null then llm_analysis.llm_attack_stage else &#34;&#34;) + &#34;\n\n&#34; +&#10;&#10;        &#34;STRIKTE REGELN (unbedingt einhalten):\n&#34; +&#10;        &#34;- Maximal **ein** Satz\n&#34; +&#10;        &#34;- Keine Risikostufe (kein kritisch, hoch, mittel etc.)\n&#34; +&#10;        &#34;- Keine Begriffe wie Angriff, Kompromittierung, Bedrohung, Eskalation bei benignen Fällen\n&#34; +&#10;        &#34;- Kein Confidence-Wert, keine Prozentzahlen\n&#34; +&#10;        &#34;- Keine Satzzeichen am Satzende\n&#34; +&#10;        &#34;- Keine Begriffe wie anomal, anormal, abnormal, anomalisch, anomalisches, anomalische, anomalischer\n&#34; +&#10;        &#34;- Ausgabe **ausschließlich** auf Deutsch\n&#34; +&#10;        &#34;- Nüchterner, faktenbasierter als Empfehlung formulierter SOC-Ton\n&#34; +&#10;        &#34;- Verwende Formulierungen wie \&#34;aufgrund von\&#34;, \&#34;basierend auf\&#34;, \&#34;durch\&#34; oder \&#34;bei\&#34;\n\n&#34; +&#10;&#10;        &#34;Antworte **AUSSCHLIESSLICH** mit folgendem JSON – kein zusätzlicher Text:\n&#34; +&#10;        &#34;{\&#34;llm_explanation_short\&#34;: \&#34;Deine eine kurze Aussage hier\&#34;}&#34;&#10;    }&#10;  ]&#10;}" target="data.payload" />
          </zeebe:ioMapping>
          <zeebe:taskHeaders>
            <zeebe:header key="elementTemplateVersion" value="3" />
            <zeebe:header key="elementTemplateId" value="io.camunda.connectors.aws.bedrock.v1" />
            <zeebe:header key="resultVariable" value="llm_explanation_raw" />
            <zeebe:header key="resultExpression" value="=from json(&#10;  trim(&#10;    replace(&#10;      replace(&#10;        body.content[1].text,&#10;        &#34;```json&#34;,&#10;        &#34;&#34;&#10;      ),&#10;      &#34;```&#34;,&#10;      &#34;&#34;&#10;    )&#10;  )&#10;)" />
            <zeebe:header key="retryBackoff" value="PT0S" />
          </zeebe:taskHeaders>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_03y4swm</bpmn:incoming>
        <bpmn:outgoing>Flow_1nka4il</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:sequenceFlow id="Flow_1nka4il" sourceRef="llm_explanation_AI" targetRef="Mini_Asset_Detection" />
      <bpmn:sequenceFlow id="Flow_0hxjfpm" sourceRef="Activity_1mmn11d" targetRef="Short_Description_AI" />
      <bpmn:scriptTask id="Activity_1mmn11d" name="Detect Real Incident">
        <bpmn:extensionElements>
          <zeebe:script expression="={&#10;  /* ======================= INPUT NORMALIZATION ======================= */&#10;&#10;  topic_clean:&#10;    lower case(&#10;      if sim_input != null and sim_input.incident_topic != null&#10;      then sim_input.incident_topic&#10;      else &#34;&#34;&#10;    ),&#10;&#10;&#10;  /* ======================= BENIGN SIGNALS ======================= */&#10;&#10;  benign_hit:&#10;&#10;    sum(&#10;      for keyword in [&#10;&#10;        &#34;geplant&#34;,&#10;        &#34;genehmigt&#34;,&#10;        &#34;security scan&#34;,&#10;        &#34;internes it-team&#34;,&#10;        &#34;change-system dokumentiert&#34;&#10;&#10;      ]&#10;&#10;      return&#10;        if contains(topic_clean, keyword)&#10;        then 1&#10;        else 0&#10;    ),&#10;&#10;&#10;  /* ======================= MALICIOUS SIGNALS ======================= */&#10;&#10;  malicious_hit:&#10;&#10;    sum(&#10;      for keyword in [&#10;&#10;        &#34;verdacht&#34;,&#10;        &#34;scanaktivität&#34;,&#10;        &#34;proxy&#34;,&#10;        &#34;vpn&#34;,&#10;        &#34;unbefugt&#34;,&#10;        &#34;datenabfluss&#34;,&#10;        &#34;zugriffe&#34;,&#10;        &#34;sql injection&#34;,&#10;        &#34;cpu-spitzen&#34;,&#10;        &#34;ungewöhnlich&#34;&#10;&#10;      ]&#10;&#10;      return&#10;        if contains(topic_clean, keyword)&#10;        then 1&#10;        else 0&#10;    ),&#10;&#10;&#10;  /* ======================= FINAL DECISION ======================= */&#10;&#10;  is_real_incident:&#10;&#10;    /* 🟢 BENIGN */&#10;    if benign_hit &#62;= 2&#10;       and malicious_hit = 0&#10;    then false&#10;&#10;    /* 🔴 INCIDENT */&#10;    else if malicious_hit &#62;= 1&#10;    then true&#10;&#10;    /* 🔵 FALLBACK */&#10;    else true&#10;}" resultVariable="detect_real_incident_result" />
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_0xm84ex</bpmn:incoming>
        <bpmn:outgoing>Flow_0hxjfpm</bpmn:outgoing>
      </bpmn:scriptTask>
    </bpmn:subProcess>
    <bpmn:sequenceFlow id="Flow_0fqftcs" sourceRef="Activity_0w8ynwr" targetRef="Gateway_05yofwt" />
    <bpmn:subProcess id="Content_Enrichment" name="Content Enrichment">
      <bpmn:incoming>Flow_1b2bwld</bpmn:incoming>
      <bpmn:outgoing>Flow_1rq39js</bpmn:outgoing>
      <bpmn:startEvent id="Event_0nm10tn">
        <bpmn:outgoing>Flow_1xsrq63</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:scriptTask id="Investigation_Duration_Builder" name="Investigation Duration Builder">
        <bpmn:extensionElements>
          <zeebe:script expression="=put all(&#10;  if incident_object = null then {} else incident_object,&#10;  {&#10;    investigation_end:&#10;      (now() - @&#34;1970-01-01T00:00Z&#34;) / @&#34;PT1S&#34; * 1000,&#10;&#10;    investigation_duration:&#10;      string(&#10;        floor(&#10;          (&#10;            ((now() - @&#34;1970-01-01T00:00Z&#34;) / @&#34;PT1S&#34; * 1000)&#10;            - investigation_start&#10;          ) / 1000&#10;        )&#10;      ) + &#34;s&#34;&#10;  }&#10;)" resultVariable="incident_object" />
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_15p7s9m</bpmn:incoming>
        <bpmn:outgoing>Flow_01jdjde</bpmn:outgoing>
      </bpmn:scriptTask>
      <bpmn:scriptTask id="Confidence_Calculation" name="Confidence Calculation">
        <bpmn:extensionElements>
          <zeebe:script expression="=put all(&#10;  if incident_object = null then {} else incident_object,&#10;&#10;  {&#10;&#10;/* ================= BASE CONFIDENCE ================= */&#10;&#10;confidence_base:&#10;&#10;  min(&#10;    1,&#10;    max(&#10;      0,&#10;&#10;      /* 🔥 INCIDENT GATE */&#10;      (&#10;        if detect_real_incident_result.is_real_incident != true&#10;        then 0.1&#10;        else incident_object.threat_confidence_raw&#10;      )&#10;&#10;      /* 🔴 DATA EXFILTRATION */&#10;      + (&#10;          if detect_real_incident_result.is_real_incident = true&#10;             and incident_object.threat_pattern = &#34;DATA_EXFILTRATION&#34;&#10;          then 0.2&#10;          else 0&#10;        )&#10;&#10;      /* 🔴 TARGETED ACCESS */&#10;      + (&#10;          if detect_real_incident_result.is_real_incident = true&#10;             and incident_object.threat_pattern = &#34;TARGETED_ACCESS&#34;&#10;          then 0.1&#10;          else 0&#10;        )&#10;&#10;      /* 🔴 SYSTEM ANOMALY */&#10;      + (&#10;          if detect_real_incident_result.is_real_incident = true&#10;             and incident_object.threat_pattern = &#34;SYSTEM_ANOMALY&#34;&#10;          then 0.05&#10;          else 0&#10;        )&#10;&#10;      /* 🟠 PROXY */&#10;      + (&#10;          if detect_real_incident_result.is_real_incident = true&#10;             and incident_object.threat_pattern = &#34;PROXY&#34;&#10;          then 0.05&#10;          else 0&#10;        )&#10;&#10;      /* 🟡 SCANNING REDUCTION */&#10;      - (&#10;          if incident_object.threat_pattern = &#34;SCAN&#34;&#10;          then 0.15&#10;          else 0&#10;        )&#10;&#10;      /* 🔵 LOW SCORE PENALTY */&#10;      - (&#10;          if incident_object.threat_score &#60; 5&#10;          then 0.1&#10;          else 0&#10;        )&#10;    )&#10;  ),&#10;&#10;&#10;/* ================= FINAL VALUES ================= */&#10;&#10;threat_confidence:&#10;&#10;  max(&#10;&#10;    confidence_base,&#10;&#10;    /* 🔥 LLM nur bei echten Incidents */&#10;    if detect_real_incident_result.is_real_incident = true&#10;       and llm_analysis.llm_confidence != null&#10;    then number(llm_analysis.llm_confidence)&#10;&#10;    else 0&#10;  ),&#10;&#10;&#10;threat_confidence_percent:&#10;  floor(confidence_base * 100),&#10;&#10;&#10;confidence_badge_class:&#10;&#10;  if confidence_base &#62;= 0.8&#10;  then &#34;badge-low&#34;&#10;&#10;  else if confidence_base &#62;= 0.5&#10;  then &#34;badge-medium&#34;&#10;&#10;  else &#34;badge-high&#34;&#10;&#10;  }&#10;)" resultVariable="incident_object" />
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_1w0atz5</bpmn:incoming>
        <bpmn:outgoing>Flow_106ngwl</bpmn:outgoing>
      </bpmn:scriptTask>
      <bpmn:scriptTask id="Calculate_Action" name="Calculate Action">
        <bpmn:extensionElements>
          <zeebe:script expression="=put all(&#10;  if incident_object = null then {} else incident_object,&#10;&#10;  {&#10;&#10;    /* ================= NORMALIZED CONFIDENCE ================= */&#10;&#10;    threat_confidence_safe:&#10;      if incident_object.threat_confidence != null&#10;      then incident_object.threat_confidence&#10;      else 0.5,&#10;&#10;&#10;  /* ================= CALCULATED ACTION ================= */&#10;&#10;calculated_action:&#10;&#10;  /* 🟢 KEIN INCIDENT */&#10;  if detect_real_incident_result.is_real_incident = false&#10;  then &#34;ignore&#34;&#10;&#10;  /* 🟢 LOW */&#10;  else if incident_object.risk_level = &#34;LOW&#34;&#10;  then &#34;monitor&#34;&#10;&#10;  /* 🔴 CRITICAL */&#10;  else if incident_object.risk_level = &#34;CRITICAL&#34;&#10;  then &#34;contain&#34;&#10;&#10;  /* 🔴 HIGH */&#10;  else if incident_object.risk_level = &#34;HIGH&#34;&#10;  then &#34;investigate&#34;&#10;&#10;  /* 🟠 MEDIUM + HIGH VALUE ASSET */&#10;  else if incident_object.risk_level = &#34;MEDIUM&#34;&#10;       and lower case(incident_object.asset_criticality) = &#34;high&#34;&#10;  then &#34;investigate&#34;&#10;&#10;  /* 🟠 DATA EXFILTRATION */&#10;  else if incident_object.threat_pattern = &#34;DATA_EXFILTRATION&#34;&#10;  then &#34;contain&#34;&#10;&#10;  /* 🟠 TARGETED ACCESS */&#10;  else if incident_object.threat_pattern = &#34;TARGETED_ACCESS&#34;&#10;  then &#34;investigate&#34;&#10;&#10;  /* 🟠 SYSTEM ANOMALY */&#10;  else if incident_object.threat_pattern = &#34;SYSTEM_ANOMALY&#34;&#10;  then &#34;investigate&#34;&#10;&#10;  /* 🟡 SCAN */&#10;  else if incident_object.threat_pattern = &#34;SCAN&#34;&#10;  then &#34;monitor&#34;&#10;&#10;  /* 🔵 LOW CONFIDENCE */&#10;  else if threat_confidence_safe &#60; 0.5&#10;  then &#34;ignore&#34;&#10;&#10;  /* 🔵 FALLBACK */&#10;  else incident_object.base_action,&#10;&#10;&#10;    /* ================= FINAL ACTION ================= */&#10;&#10;    action:&#10;      calculated_action,&#10;&#10;    action_lower:&#10;      lower case(action),&#10;&#10;    action_priority:&#10;      if action = &#34;contain&#34; then &#34;critical&#34;&#10;      else if action = &#34;investigate&#34; then &#34;high&#34;&#10;      else if action = &#34;monitor&#34; then &#34;medium&#34;&#10;      else &#34;low&#34;,&#10;&#10;    requires_human:&#10;      if action = &#34;contain&#34; then true&#10;      else if threat_confidence_safe &#60; 0.5 then true&#10;      else false,&#10;&#10;&#10;  /* ================= DEBUG ================= */&#10;&#10;debug_base_action:&#10;  base_action,&#10;&#10;&#10;debug_calculated_action:&#10;  calculated_action,&#10;&#10;&#10;debug_final_action:&#10;  action,&#10;&#10;&#10;debug_pattern:&#10;  incident_object.threat_pattern,&#10;&#10;&#10;debug_action_rule:&#10;&#10;  /* 🔴 CRITICAL → CONTAIN */&#10;  if action = &#34;contain&#34;&#10;     and incident_object.risk_level = &#34;CRITICAL&#34;&#10;  then &#34;CRITICAL_CONTAIN&#34;&#10;&#10;  /* 🟠 HIGH → INVESTIGATE */&#10;  else if action = &#34;investigate&#34;&#10;       and incident_object.risk_level = &#34;HIGH&#34;&#10;  then &#34;HIGH_INVESTIGATE&#34;&#10;&#10;  /* 🟡 MEDIUM → MONITOR */&#10;  else if action = &#34;monitor&#34;&#10;       and incident_object.risk_level = &#34;MEDIUM&#34;&#10;  then &#34;MEDIUM_MONITOR&#34;&#10;&#10;  /* 🟢 LOW → IGNORE */&#10;  else if action = &#34;ignore&#34;&#10;       and incident_object.risk_level = &#34;LOW&#34;&#10;  then &#34;LOW_IGNORE&#34;&#10;&#10;  /* 🔶 LOW CONFIDENCE */&#10;  else if threat_confidence_safe &#60; 0.5&#10;  then &#34;CONFIDENCE_DOWNGRADE&#34;&#10;&#10;  /* 🔶 HIGH CONFIDENCE */&#10;  else if threat_confidence_safe &#62;= 0.8&#10;  then &#34;CONFIDENCE_UPGRADE&#34;&#10;&#10;  /* 🔍 ROOT CAUSE */&#10;  else if incident_object.is_gdpr_relevant&#10;  then &#34;GDPR&#34;&#10;&#10;  else if incident_object.threat_pattern = &#34;DATA_EXFILTRATION&#34;&#10;  then &#34;EXFIL&#34;&#10;&#10;  else if incident_object.threat_pattern = &#34;TARGETED_ACCESS&#34;&#10;  then &#34;TARGETED_ACCESS&#34;&#10;&#10;  else if incident_object.threat_pattern = &#34;SYSTEM_ANOMALY&#34;&#10;  then &#34;SYSTEM&#34;&#10;&#10;  else &#34;FALLBACK&#34;,&#10;&#10;&#10;debug_risk_rule:&#10;&#10;  if incident_object.is_gdpr_relevant&#10;  then &#34;GDPR&#34;&#10;&#10;  else if incident_object.behavior_risk_boost = 2&#10;  then &#34;BEHAVIOR_OVERRIDE&#34;&#10;&#10;  else if incident_object.threat_pattern = &#34;DATA_EXFILTRATION&#34;&#10;  then &#34;EXFIL&#34;&#10;&#10;  else if incident_object.threat_pattern = &#34;TARGETED_ACCESS&#34;&#10;  then &#34;TARGETED_ACCESS&#34;&#10;&#10;  else if incident_object.threat_pattern = &#34;SYSTEM_ANOMALY&#34;&#10;  then &#34;SYSTEM&#34;&#10;&#10;  else if incident_object.impact = &#34;1&#34;&#10;  then &#34;IMPACT_CRITICAL&#34;&#10;&#10;  else &#34;FALLBACK&#34;&#10;&#10;&#10;  }&#10;)" resultVariable="incident_object" />
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_106ngwl</bpmn:incoming>
        <bpmn:outgoing>Flow_0xiuyw4</bpmn:outgoing>
      </bpmn:scriptTask>
      <bpmn:scriptTask id="Build_Investigation_Report" name="Build Investigation Report">
        <bpmn:extensionElements>
          <zeebe:script expression="=put all(&#10;  if incident_object = null then {} else incident_object,&#10;&#10;  {&#10;&#10;    investigation_report:&#10;&#10;(&#10;  if ai_extract != null&#10;  then string(ai_extract.iso_report)&#10;  else &#34;Kein ISO Bericht vorhanden&#34;&#10;)&#10;&#10;    +&#10;&#10;    &#34;\n\n---\n&#34;&#10;&#10;    +&#10;&#10;    (&#10;      &#34;\n\n### &#34; + incident_object.report_labels.ai_decision + &#34; ###\n&#34;&#10;      +&#10;      &#34;Entscheidung: &#34; + upper case(&#10;        string(&#10;          if incident_object.action != null&#10;          then incident_object.action&#10;          else &#34;Unbekannt&#34;&#10;        )&#10;      ) + &#34;\n&#34;&#10;      +&#10;      &#34;Priorität: &#34; + upper case(&#10;        string(&#10;          if incident_object.action_priority != null&#10;          then incident_object.action_priority&#10;          else &#34;Unbekannt&#34;&#10;        )&#10;      ) + &#34;\n&#34;&#10;      +&#10;      &#34;Begründung: &#34; +&#10;      (&#10;        if incident_object.llm_explanation_short != null&#10;        then string(incident_object.llm_explanation_short)&#10;        else &#34;Keine Begründung angeben&#34;&#10;      )&#10;    )&#10;&#10;    +&#10;&#10;    (&#10;    if incident_object.threat_score != null&#10;     and incident_object.threat_score &#62; 0&#10;      then&#10;        &#34;\n\n### &#34; + incident_object.report_labels.threat_intel + &#34; ###\n&#34;&#10;        +&#10;        &#34;Quell-IP: &#34; + string(incident_object.incident_ip) + &#34;\n&#34;&#10;        +&#10;        &#34;Bedrohungshost: &#34; + string(incident_object.threat_host) + &#34;\n&#34;&#10;        +&#10;        &#34;Bedrohungswert: &#34; + string(incident_object.threat_score) + &#34;\n&#34;&#10;        +&#10;        &#34;Bedrohungsstufe: &#34; + string(incident_object.threat_level) + &#34;\n&#34;&#10;        +&#10;        &#34;Offene Ports: &#34;&#10;        +&#10;        (&#10;          if incident_object.threat_ports != null&#10;             and count(incident_object.threat_ports) &#62; 0&#10;          then string join(&#10;            for p in incident_object.threat_ports return string(p),&#10;            &#34;, &#34;&#10;          )&#10;          else &#34;none&#34;&#10;        )&#10;      else &#34;&#34;&#10;    )&#10;&#10;    +&#10;&#10;    (&#10;    if incident_object.asset_visible = true&#10;      then&#10;        &#34;\n\n### &#34; + incident_object.report_labels.asset + &#34; ###\n&#34;&#10;        +&#10;        &#34;Systemtyp: &#34; + string(incident_object.asset_type) + &#34;\n&#34;&#10;        +&#10;        &#34;Systemverantwortlicher: &#34; + string(incident_object.asset_owner) + &#34;\n&#34;&#10;        +&#10;        &#34;Kritikalität: &#34; + string(incident_object.asset_criticality_label)&#10;      else &#34;&#34;&#10;    )&#10;  }&#10;)" resultVariable="incident_object" />
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_0itfbyx</bpmn:incoming>
        <bpmn:outgoing>Flow_15p7s9m</bpmn:outgoing>
      </bpmn:scriptTask>
      <bpmn:sequenceFlow id="Flow_01jdjde" sourceRef="Investigation_Duration_Builder" targetRef="Event_0odbb3h" />
      <bpmn:sequenceFlow id="Flow_15p7s9m" sourceRef="Build_Investigation_Report" targetRef="Investigation_Duration_Builder" />
      <bpmn:sequenceFlow id="Flow_106ngwl" sourceRef="Confidence_Calculation" targetRef="Calculate_Action" />
      <bpmn:sequenceFlow id="Flow_0xiuyw4" sourceRef="Calculate_Action" targetRef="Report_Enrichment" />
      <bpmn:sequenceFlow id="Flow_1xsrq63" sourceRef="Event_0nm10tn" targetRef="Unified_Incident_Builder" />
      <bpmn:endEvent id="Event_0odbb3h">
        <bpmn:incoming>Flow_01jdjde</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_19197k3" sourceRef="Report_Enrichment" targetRef="Activity_1d33b1r" />
      <bpmn:scriptTask id="Report_Enrichment" name="Report Enrichment">
        <bpmn:extensionElements>
          <zeebe:script expression="=put all(&#10;  if incident_object = null then {} else incident_object,&#10;  &#10;  {&#10;&#10;    /* ================= RISK ANGLE ================= */&#10;&#10;    risk_needle_angle:&#10;&#10;      max(&#10;        -67.5,&#10;        min(&#10;          67.5,&#10;&#10;          (&#10;            if upper case(trim(incident_object.risk_level)) = &#34;LOW&#34; then -67.5&#10;            else if upper case(trim(incident_object.risk_level)) = &#34;MEDIUM&#34; then -22.5&#10;            else if upper case(trim(incident_object.risk_level)) = &#34;HIGH&#34; then 22.5&#10;            else if upper case(trim(incident_object.risk_level)) = &#34;CRITICAL&#34; then 67.5&#10;            else 0&#10;          )&#10;&#10;          +&#10;&#10;          (&#10;            if upper case(trim(incident_object.risk_level)) = &#34;CRITICAL&#34;&#10;            then 0&#10;            else (random number() * 8) - 4&#10;          )&#10;&#10;        )&#10;      ),&#10;&#10;&#10;    /* ================= ACTION ANGLE ================= */&#10;&#10;    action_needle_angle:&#10;&#10;      max(&#10;        -67.5,&#10;        min(&#10;          67.5,&#10;&#10;          (&#10;            if upper case(trim(incident_object.action)) = &#34;IGNORE&#34; then -67.5&#10;            else if upper case(trim(incident_object.action)) = &#34;MONITOR&#34; then -22.5&#10;            else if upper case(trim(incident_object.action)) = &#34;INVESTIGATE&#34; then 22.5&#10;            else if upper case(trim(incident_object.action)) = &#34;CONTAIN&#34; then 67.5&#10;            else if upper case(trim(incident_object.action)) = &#34;BLOCK&#34; then 67.5&#10;            else 0&#10;          )&#10;&#10;          +&#10;&#10;          (&#10;            if upper case(trim(incident_object.action)) = &#34;CONTAIN&#34;&#10;            then 0&#10;            else (random number() * 8) - 4&#10;          )&#10;&#10;        )&#10;      ),&#10;&#10;&#10;    /* ================= RISK COLOR ================= */&#10;&#10;    risk_color:&#10;&#10;      if upper case(trim(incident_object.risk_level)) = &#34;LOW&#34; then &#34;green&#34;&#10;      else if upper case(trim(incident_object.risk_level)) = &#34;MEDIUM&#34; then &#34;blue&#34;&#10;      else if upper case(trim(incident_object.risk_level)) = &#34;HIGH&#34; then &#34;orange&#34;&#10;      else if upper case(trim(incident_object.risk_level)) = &#34;CRITICAL&#34; then &#34;red&#34;&#10;      else &#34;gray&#34;&#10;&#10;&#10;&#10;  }&#10;)" resultVariable="incident_object" />
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_0xiuyw4</bpmn:incoming>
        <bpmn:outgoing>Flow_19197k3</bpmn:outgoing>
      </bpmn:scriptTask>
      <bpmn:scriptTask id="Unified_Incident_Builder" name="Unified Incident Builder">
        <bpmn:extensionElements>
          <zeebe:script expression="={&#10;&#10;report_labels:&#10;{&#10;  incident_summary: &#34;VORFALLSÜBERSICHT&#34;,&#10;  threat_intel: &#34;TECHNISCHE BEDROHUNGSANALYSE&#34;,&#10;  asset: &#34;BETROFFENES SYSTEM&#34;,&#10;  gdpr: &#34;DSGVO-RISIKOANALYSE&#34;,&#10;  human_review: &#34;MANUELLE PRÜFUNG&#34;,&#10;  ai_log: &#34;KI-ENTSCHEIDUNGSPROTOKOLL&#34;,&#10;  ai_decision: &#34;KI-ENTSCHEIDUNG&#34;,&#10;  gdpr_aborted: &#34;DSGVO-PRÜFUNG DURCH PRÜFER ABGEBROCHEN&#34;,&#10;  reason: &#34;BEGRÜNDUNG&#34;,&#10;  decision: &#34;ENTSCHEIDUNG&#34;,&#10;  ai_recommendation: &#34;KI-EMPFOHLENE PRIORITÄT&#34;,&#10;  final_priority: &#34;ENDGÜLTIGE PRIORITÄT&#34;,&#10;  auditor_comment: &#34;PRÜFERKOMMENTAR&#34;,&#10;  impact: &#34;AUSWIRKUNG&#34;,&#10;  urgency: &#34;DRINGLICHKEIT&#34;&#10;},&#10;  &#10;report_labels_en:&#10;{&#10;  incident_summary: &#34;INCIDENT SUMMARY&#34;,&#10;  threat_intel: &#34;TECHNICAL THREAT INTELLIGENCE&#34;,&#10;  asset: &#34;AFFECTED SYSTEM&#34;,&#10;  gdpr: &#34;GDPR RISK ANALYSIS&#34;,&#10;  human_review: &#34;HUMAN REVIEW&#34;,&#10;  ai_log: &#34;AI DECISION LOG&#34;,&#10;  ai_decision: &#34;AI DECISION&#34;,&#10;  gdpr_aborted: &#34;GDPR INVESTIGATION ABORTED BY AUDITOR&#34;,&#10;  reason: &#34;Reason&#34;,&#10;  decision: &#34;Decision&#34;,&#10;  ai_recommendation: &#34;AI Recommended Priority&#34;,&#10;  final_priority: &#34;Final Priority&#34;,&#10;  auditor_comment: &#34;Auditor Comment&#34;,&#10;  impact: &#34;Impact&#34;,&#10;  urgency: &#34;Urgency&#34;&#10;},&#10;  &#10;&#10;  &#10;  &#10;action_labels:&#10;{&#10;  contain: &#34;Eindämmen&#34;,&#10;  investigate: &#34;Untersuchen&#34;,&#10;  monitor: &#34;Beobachten&#34;,&#10;  ignore: &#34;Ignorieren&#34;&#10;},&#10;&#10;short_description_long:&#10;  sim_input.incident_topic,&#10;&#10;&#10;&#10;&#10;  &#10;/* ================= SHORT DESCRIPTION speziell für Tickets ================= */  &#10;short_description_temp:&#10;  if short_description_raw != null&#10;  then&#10;    if contains(short_description_raw.body.content[1].text, &#34;short_description&#34;)&#10;    then&#10;      substring before(&#10;        substring after(&#10;          short_description_raw.body.content[1].text,&#10;          &#34;: \&#34;&#34;&#10;        ),&#10;        &#34;\&#34;&#34;&#10;      )&#10;    else short_description_raw.body.content[1].text&#10;  else sim_input.incident_topic,&#10;&#10;short_description:&#10;  short_description_temp,&#10;&#10;&#10;&#10;  &#10;/* ================= SHORT EXPLANATION speziell für KI-Bewertung Anzeige ================= */  &#10;llm_explanation_temp:&#10;  if llm_explanation_raw != null&#10;  then&#10;    if contains(llm_explanation_raw.body.content[1].text, &#34;llm_explanation&#34;)&#10;    then&#10;      substring before(&#10;        substring after(&#10;          llm_explanation_raw.body.content[1].text,&#10;          &#34;: \&#34;&#34;&#10;        ),&#10;        &#34;\&#34;&#34;&#10;      )&#10;    else llm_explanation_raw.body.content[1].text&#10;  else &#34;Keine Beschreibung verfügbar&#34;,&#10;&#10;llm_explanation_short:&#10;  llm_explanation_temp,&#10;  &#10;  &#10;topic:&#10;  lower case(&#10;    if sim_input != null and sim_input.incident_topic != null&#10;    then sim_input.incident_topic&#10;    else &#34;&#34;&#10;  ),&#10;&#10;&#10;&#10;  &#10;&#10;/* ---------------- THREAT CATEGORY ---------------- */&#10;&#10;threat_category:&#10;&#10;  if detect_real_incident_result.is_real_incident = false&#10;  then &#34;KEIN VORFALL&#34;&#10;&#10;  else if contains(topic,&#34;datenabfluss&#34;)&#10;       or contains(topic,&#34;sql injection&#34;)&#10;       or contains(topic,&#34;kundendaten&#34;)&#10;       or contains(topic,&#34;personenbezogene daten&#34;)&#10;  then &#34;DATA_BREACH&#34;&#10;&#10;  else if contains(topic,&#34;proxy&#34;)&#10;       or contains(topic,&#34;vpn&#34;)&#10;  then &#34;PROXY&#34;&#10;&#10;  else if contains(topic,&#34;scan&#34;)&#10;  then &#34;SCANNING&#34;&#10;&#10;  else if contains(topic,&#34;cpu&#34;)&#10;       or contains(topic,&#34;prozesse&#34;)&#10;       or contains(topic,&#34;auth-01&#34;)&#10;  then &#34;SYSTEM&#34;&#10;&#10;  else &#34;GENERIC&#34;,&#10;&#10;&#10;is_critical_threat:&#10;&#10;  threat_category = &#34;DATA_BREACH&#34;&#10;  or threat_category = &#34;PROXY&#34;,&#10;&#10;&#10;&#10;&#10;  &#10;  &#10;/* ---------------- GDPR ---------------- */&#10;&#10;gdpr_assessment:&#10;  if gdpr_raw != null&#10;  then gdpr_raw.body.content[1].text&#10;  else null,&#10;&#10;&#10;is_gdpr_relevant:&#10;&#10;  /* 🔥 NUR ECHTE INCIDENTS */&#10;  if detect_real_incident_result.is_real_incident != true&#10;  then false&#10;&#10;  /* 🔴 DSGVO-HINWEISE AUS TESTFÄLLEN */&#10;  else if&#10;    contains(topic,&#34;personenbezogene&#34;)&#10;    or contains(topic,&#34;kundendaten&#34;)&#10;    or contains(topic,&#34;kundenprofilen&#34;)&#10;    or contains(topic,&#34;kontaktdaten&#34;)&#10;    or contains(topic,&#34;adresse&#34;)&#10;    or contains(topic,&#34;e-mail&#34;)&#10;    or contains(topic,&#34;datenabfluss&#34;)&#10;  then true&#10;&#10;  /* 🔴 LLM BESTÄTIGT DSGVO */&#10;  else if&#10;    gdpr_raw != null&#10;    and gdpr_assessment != null&#10;    and contains(lower case(gdpr_assessment),&#34;relevanz: ja&#34;)&#10;  then true&#10;&#10;  else false,&#10;&#10;&#10;gdpr_source:&#10;&#10;  if detect_real_incident_result.is_real_incident != true&#10;  then &#34;none&#34;&#10;&#10;  else if&#10;    contains(topic,&#34;personenbezogene&#34;)&#10;    or contains(topic,&#34;kundendaten&#34;)&#10;    or contains(topic,&#34;kundenprofilen&#34;)&#10;    or contains(topic,&#34;kontaktdaten&#34;)&#10;    or contains(topic,&#34;adresse&#34;)&#10;    or contains(topic,&#34;e-mail&#34;)&#10;    or contains(topic,&#34;datenabfluss&#34;)&#10;  then &#34;rule_based&#34;&#10;&#10;  else if&#10;    gdpr_raw != null&#10;    and gdpr_assessment != null&#10;  then &#34;llm_based&#34;&#10;&#10;  else &#34;none&#34;,&#10;&#10;&#10;gdpr_categories:&#10;  if gdpr_assessment != null&#10;  then trim(&#10;         substring before(&#10;           substring after(gdpr_assessment,&#34;KATEGORIE:&#34;),&#10;           &#34;\n&#34;&#10;         )&#10;       )&#10;  else null,&#10;&#10;&#10;gdpr_risk_level:&#10;  if gdpr_assessment != null&#10;  then trim(&#10;         substring before(&#10;           substring after(gdpr_assessment,&#34;RISIKO-EINSCHÄTZUNG:&#34;),&#10;           &#34;\n&#34;&#10;         )&#10;       )&#10;  else null,&#10;&#10;&#10;gdpr_measure:&#10;  if gdpr_assessment != null&#10;  then trim(&#10;         substring before(&#10;           substring after(gdpr_assessment,&#34;MAßNAHME:&#34;),&#10;           &#34;\n&#34;&#10;         )&#10;       )&#10;  else null,&#10;&#10;&#10;gdpr_relevance:&#10;  if is_gdpr_relevant then &#34;JA&#34; else &#34;NEIN&#34;,&#10;&#10;&#10;gdpr_visible:&#10;&#10;  contains(&#10;    string(agent_plan.tools),&#10;    &#34;check_gdpr_relevance&#34;&#10;  ),&#10;  &#10;&#10;&#10;&#10;  &#10;/* ---------------- THREAT CONFIDENCE ---------------- */  &#10;  &#10;threat_confidence_raw:&#10;&#10;  if llm_analysis.llm_confidence != null&#10;  then min(1, max(0, llm_analysis.llm_confidence))&#10;&#10;  else 0.5,&#10;&#10;&#10;&#10;  &#10;&#10;/* ---------------- THREAT INTEL ---------------- */&#10;&#10;threat_score:&#10;&#10;  if threat_intel != null and threat_intel.body != null&#10;  then&#10;    (if threat_intel.body.ports != null then count(threat_intel.body.ports) else 0)&#10;    +&#10;    (if threat_intel.body.tags != null then count(threat_intel.body.tags) * 2 else 0)&#10;  else 0,&#10;  &#10;&#10;&#10;&#10;  &#10;&#10;/* ---------------- THREAT DETAILS ---------------- */&#10;&#10;threat_host:&#10;  if threat_intel != null&#10;     and threat_intel.body != null&#10;     and threat_intel.body.hostnames != null&#10;     and count(threat_intel.body.hostnames) &#62; 0&#10;  then threat_intel.body.hostnames[1]&#10;  else &#34;Unbekannt&#34;,&#10;&#10;&#10;threat_ports:&#10;  if threat_intel != null&#10;     and threat_intel.body != null&#10;     and threat_intel.body.ports != null&#10;  then threat_intel.body.ports&#10;  else [],&#10;&#10;&#10;threat_ports_string:&#10;  if threat_ports = null or count(threat_ports) = 0&#10;  then &#34;none&#34;&#10;&#10;  else&#10;    string join(&#10;      for p in threat_ports&#10;      return string(p),&#10;      &#34;, &#34;&#10;    ),&#10;&#10;&#10;threat_tags_string:&#10;  if threat_intel != null&#10;     and threat_intel.body != null&#10;     and threat_intel.body.tags != null&#10;     and count(threat_intel.body.tags) &#62; 0&#10;  then string join(threat_intel.body.tags, &#34;, &#34;)&#10;  else &#34;none&#34;,&#10;&#10;&#10;threat_services_string:&#10;  if threat_intel != null&#10;     and threat_intel.body != null&#10;     and threat_intel.body.cpes != null&#10;     and count(threat_intel.body.cpes) &#62; 0&#10;  then string join(&#10;         for c in threat_intel.body.cpes&#10;         return substring after(c, &#34;cpe:/a:&#34;),&#10;         &#34;, &#34;&#10;       )&#10;  else &#34;Unbekannt&#34;,&#10;&#10;&#10;threat_hostnames_string:&#10;  if threat_intel != null&#10;     and threat_intel.body != null&#10;     and threat_intel.body.hostnames != null&#10;     and count(threat_intel.body.hostnames) &#62; 0&#10;  then string join(threat_intel.body.hostnames, &#34;, &#34;)&#10;  else &#34;none&#34;,&#10;&#10;&#10;/* 🔥 TESTFÄLLE NUTZEN KEINE DNS-/TRUSTED-INFRA-LOGIK */&#10;&#10;is_known_dns:&#10;  false,&#10;&#10;&#10;is_trusted_infrastructure:&#10;  false,&#10;&#10;&#10;  &#10;&#10;  &#10;&#10;/* ================= THREAT ROLE ================= */&#10;&#10;threat_role:&#10;&#10;  /* 🔴 1. Threat AI */&#10;  if threat_ai_analysis != null&#10;     and threat_ai_analysis.threat_role != null&#10;     and threat_ai_analysis.threat_role != &#34;&#34;&#10;  then upper case(threat_ai_analysis.threat_role)&#10;&#10;  /* 🔴 2. Bestehender Wert */&#10;  else if threat_role != null&#10;       and threat_role != &#34;&#34;&#10;       and threat_role != &#34;UNKNOWN&#34;&#10;       and threat_role != &#34;Unbekannt&#34;&#10;  then threat_role&#10;&#10;  /* 🔴 3. Testfallbasierte Threat-Erkennung */&#10;  else if contains(topic,&#34;datenabfluss&#34;)&#10;       or contains(topic,&#34;sql injection&#34;)&#10;       or contains(topic,&#34;kundendaten&#34;)&#10;  then &#34;DATA_EXFILTRATION&#34;&#10;&#10;  else if contains(topic,&#34;proxy&#34;)&#10;       or contains(topic,&#34;vpn&#34;)&#10;  then &#34;PROXY&#34;&#10;&#10;  else if contains(topic,&#34;scan&#34;)&#10;  then &#34;SCANNER&#34;&#10;&#10;  else if contains(topic,&#34;cpu&#34;)&#10;       or contains(topic,&#34;prozesse&#34;)&#10;       or contains(topic,&#34;auth-01&#34;)&#10;  then &#34;SYSTEM&#34;&#10;&#10;  else &#34;UNKNOWN&#34;,&#10;&#10;&#10;  &#10;&#10;&#10;/* ================= INFRASTRUCTURE ================= */&#10;&#10;infrastructure_type:&#10;&#10;  /* 🔴 1. Threat AI */&#10;  if threat_ai_analysis != null&#10;     and threat_ai_analysis.ai_infrastructure_type != null&#10;     and threat_ai_analysis.ai_infrastructure_type != &#34;&#34;&#10;  then upper case(threat_ai_analysis.ai_infrastructure_type)&#10;&#10;  /* 🔴 2. Bestehenden Wert behalten */&#10;  else if infrastructure_type != null&#10;       and infrastructure_type != &#34;&#34;&#10;       and infrastructure_type != &#34;UNKNOWN&#34;&#10;       and infrastructure_type != &#34;Unbekannt&#34;&#10;  then infrastructure_type&#10;&#10;  /* 🔴 3. Testfallbasierte Infrastruktur */&#10;  else if contains(topic,&#34;proxy&#34;)&#10;       or contains(topic,&#34;vpn&#34;)&#10;  then &#34;PUBLIC_SERVER&#34;&#10;&#10;  else if contains(topic,&#34;scan&#34;)&#10;  then &#34;SCANNING_INFRA&#34;&#10;&#10;  else if contains(topic,&#34;datenabfluss&#34;)&#10;       or contains(topic,&#34;sql injection&#34;)&#10;  then &#34;DATA_CHANNEL&#34;&#10;&#10;  else &#34;UNKNOWN&#34;,&#10;&#10;&#10;  &#10;&#10;&#10;&#10;/* ---------------- THREAT PATTERN ---------------- */&#10;&#10;threat_pattern:&#10;&#10;/* 🟢 KEIN INCIDENT */&#10;if detect_real_incident_result.is_real_incident = false&#10;then &#34;LEGITIME AKTIVITÄT&#34;&#10;&#10;/* 🔴 DATA EXFILTRATION */&#10;else if contains(topic,&#34;datenabfluss&#34;)&#10;     or contains(topic,&#34;sql injection&#34;)&#10;     or contains(topic,&#34;kundendaten&#34;)&#10;then &#34;DATA_EXFILTRATION&#34;&#10;&#10;/* 🔴 SYSTEM ANOMALY */&#10;else if contains(topic,&#34;cpu&#34;)&#10;     or contains(topic,&#34;prozess&#34;)&#10;     or contains(topic,&#34;prozesse&#34;)&#10;     or contains(topic,&#34;auth-01&#34;)&#10;then &#34;SYSTEM_ANOMALY&#34;&#10;&#10;/* 🔴 VPN / PROXY */&#10;else if contains(topic,&#34;vpn&#34;)&#10;     or contains(topic,&#34;proxy&#34;)&#10;then &#34;PROXY&#34;&#10;&#10;/* 🔴 SCANNING */&#10;else if contains(topic,&#34;scan&#34;)&#10;then &#34;SCAN&#34;&#10;&#10;/* 🟠 TARGETED ACCESS */&#10;else if contains(topic,&#34;104.200.20.46&#34;)&#10;then &#34;TARGETED_ACCESS&#34;&#10;&#10;/* 🟡 FALLBACK */&#10;else &#34;GENERIC&#34;,&#10;&#10;&#10;  &#10;&#10;&#10;&#10;&#10;/* ---------------- LLM SANITIZATION ---------------- */&#10;&#10;sanitized_attack_stage:&#10;&#10;  if detect_real_incident_result.is_real_incident = false&#10;  then &#34;none&#34;&#10;&#10;  else if threat_pattern = &#34;DATA_EXFILTRATION&#34;&#10;  then &#34;exfiltration&#34;&#10;&#10;  else if threat_pattern = &#34;PROXY&#34;&#10;  then &#34;initial_access&#34;&#10;&#10;  else if threat_pattern = &#34;SCAN&#34;&#10;  then &#34;reconnaissance&#34;&#10;&#10;  else if threat_pattern = &#34;SYSTEM_ANOMALY&#34;&#10;  then &#34;execution&#34;&#10;&#10;  else &#34;unknown&#34;,&#10;&#10;&#10;&#10;  &#10;&#10;&#10;/* ---------------- IMPACT / URGENCY ---------------- */&#10;&#10;impact:&#10;&#10;  if is_gdpr_relevant&#10;  then &#34;1&#34;&#10;&#10;  else if threat_pattern = &#34;DATA_EXFILTRATION&#34;&#10;  then &#34;1&#34;&#10;&#10;  else if threat_pattern = &#34;PROXY&#34;&#10;  then &#34;1&#34;&#10;&#10;  else if threat_pattern = &#34;TARGETED_ACCESS&#34;&#10;  then &#34;1&#34;&#10;&#10;  else if threat_pattern = &#34;SCAN&#34;&#10;  then &#34;2&#34;&#10;&#10;  else &#34;3&#34;,&#10;&#10;&#10;impact_label:&#10;&#10;  if impact = &#34;1&#34;&#10;  then &#34;HIGH&#34;&#10;&#10;  else if impact = &#34;2&#34;&#10;  then &#34;MEDIUM&#34;&#10;&#10;  else &#34;LOW&#34;,&#10;&#10;&#10;impact_badge_class:&#10;&#10;  if impact = &#34;1&#34;&#10;  then &#34;badge-high&#34;&#10;&#10;  else if impact = &#34;2&#34;&#10;  then &#34;badge-medium&#34;&#10;&#10;  else &#34;badge-low&#34;,&#10;&#10;&#10;urgency:&#10;&#10;  if is_gdpr_relevant&#10;  then &#34;1&#34;&#10;&#10;  else if risk_level = &#34;HIGH&#34;&#10;  then &#34;1&#34;&#10;&#10;  else if threat_pattern = &#34;TARGETED_ACCESS&#34;&#10;  then &#34;1&#34;&#10;&#10;  else if threat_pattern = &#34;SCAN&#34;&#10;  then &#34;2&#34;&#10;&#10;  else &#34;3&#34;,&#10;&#10;&#10;urgency_label:&#10;&#10;  if urgency = &#34;1&#34;&#10;  then &#34;HIGH&#34;&#10;&#10;  else if urgency = &#34;2&#34;&#10;  then &#34;MEDIUM&#34;&#10;&#10;  else &#34;LOW&#34;,&#10;&#10;&#10;urgency_badge_class:&#10;&#10;  if urgency = &#34;1&#34;&#10;  then &#34;badge-high&#34;&#10;&#10;  else if urgency = &#34;2&#34;&#10;  then &#34;badge-medium&#34;&#10;&#10;  else &#34;badge-low&#34;,&#10;&#10;&#10;&#10;  &#10;  &#10;&#10;/* ================== ASSET ================== */&#10;&#10;/* 🔥 ASSET BRIDGE (NORMALIZATION) */&#10;&#10;asset_name:&#10;&#10;  /* 🔴 1. LOOKUP */&#10;  if asset_result != null&#10;     and asset_result.asset_name != null&#10;     and asset_result.asset_name != &#34;&#34;&#10;  then asset_result.asset_name&#10;&#10;  /* 🔴 2. AI EXTRACTOR */&#10;  else if asset_detection != null&#10;       and asset_detection.asset_hint != null&#10;       and asset_detection.asset_hint != &#34;&#34;&#10;  then asset_detection.asset_hint&#10;&#10;  /* 🔴 3. TESTFALL-FALLBACKS */&#10;  else if contains(topic,&#34;AUTH-01&#34;)&#10;  then &#34;AUTH-01&#34;&#10;&#10;  else if contains(topic,&#34;CRM-PROD-02&#34;)&#10;  then &#34;CRM-PROD-02&#34;&#10;&#10;  else if contains(topic,&#34;DB-PROD-02&#34;)&#10;  then &#34;DB-PROD-02&#34;&#10;&#10;  /* 🟡 4. FINAL */&#10;  else null,&#10;&#10;&#10;asset_type:&#10;&#10;  /* 🔴 1. TESTFALL-ASSETS */&#10;  if contains(topic,&#34;AUTH-01&#34;)&#10;     or contains(topic,&#34;CRM-PROD-02&#34;)&#10;     or contains(topic,&#34;DB-PROD-02&#34;)&#10;     or contains(topic,&#34;server&#34;)&#10;     or contains(topic,&#34;system&#34;)&#10;  then &#34;Internal&#34;&#10;&#10;  /* 🔴 2. LOOKUP */&#10;  else if asset_result != null&#10;       and asset_result.asset_type != null&#10;       and asset_result.asset_type != &#34;&#34;&#10;       and lower case(asset_result.asset_type) != &#34;unbekannt&#34;&#10;  then asset_result.asset_type&#10;&#10;  /* 🔴 3. FALLBACK */&#10;  else if asset_name != null&#10;  then &#34;Internal&#34;&#10;&#10;  /* 🟡 4. FINAL */&#10;  else &#34;Unbekannt&#34;,&#10;&#10;&#10;asset_type_badge_class:&#10;&#10;  if lower case(asset_type) = &#34;internal&#34;&#10;  then &#34;badge-low&#34;&#10;&#10;  else if lower case(asset_type) = &#34;external&#34;&#10;  then &#34;badge-info&#34;&#10;&#10;  else &#34;badge-secondary&#34;,&#10;&#10;&#10;  &#10;  &#10;&#10;&#10;&#10;/* ---------------- BEHAVIOR OVERRIDE ---------------- */&#10;&#10;behavior_risk_boost:&#10;&#10;  if detect_real_incident_result.is_real_incident = true&#10;     and lower case(asset_type) = &#34;internal&#34;&#10;     and threat_pattern = &#34;DATA_EXFILTRATION&#34;&#10;  then 2&#10;&#10;  else if detect_real_incident_result.is_real_incident = true&#10;       and threat_pattern = &#34;SYSTEM_ANOMALY&#34;&#10;  then 1&#10;&#10;  else if detect_real_incident_result.is_real_incident = true&#10;       and threat_pattern = &#34;TARGETED_ACCESS&#34;&#10;  then 1&#10;&#10;  else 0,&#10;&#10;&#10;/* 🔥 EFFECTIVE RISK DRIVER */&#10;&#10;effective_risk_driver:&#10;&#10;  if behavior_risk_boost = 2&#10;  then &#34;BEHAVIOR_DOMINANT&#34;&#10;&#10;  else if behavior_risk_boost = 1&#10;  then &#34;BALANCED&#34;&#10;&#10;  else &#34;ASSET_DOMINANT&#34;,&#10;&#10;&#10;  &#10;  &#10;  &#10;&#10;&#10;/* ---------------- OWNER ---------------- */&#10;&#10;asset_owner:&#10;&#10;  /* 🔴 1. LOOKUP */&#10;  if asset_result != null&#10;     and asset_result.asset_owner != null&#10;     and asset_result.asset_owner != &#34;&#34;&#10;     and lower case(asset_result.asset_owner) != &#34;unbekannt&#34;&#10;  then asset_result.asset_owner&#10;&#10;  /* 🔴 2. TESTFALL-FALLBACK */&#10;  else if asset_name != null&#10;  then&#10;    if starts with(asset_name, &#34;DB-&#34;)&#10;    then &#34;Database Operations&#34;&#10;&#10;    else if starts with(asset_name, &#34;AUTH-&#34;)&#10;    then &#34;Identity Services&#34;&#10;&#10;    else if starts with(asset_name, &#34;CRM-&#34;)&#10;    then &#34;CRM Operations&#34;&#10;&#10;    else &#34;Internal IT&#34;&#10;&#10;  /* 🟡 3. FINAL */&#10;  else &#34;Unbekannt&#34;,&#10;&#10;&#10;asset_owner_badge_class:&#10;&#10;  if asset_owner = &#34;Unbekannt&#34;&#10;  then &#34;badge-secondary&#34;&#10;&#10;  else &#34;badge-info&#34;,&#10;&#10;&#10;  &#10;&#10;&#10;/* ---------------- CRITICALITY ---------------- */&#10;&#10;asset_criticality:&#10;&#10;  /* 🔴 1. LOOKUP */&#10;  if asset_result != null&#10;     and asset_result.asset_criticality != null&#10;     and asset_result.asset_criticality != &#34;&#34;&#10;     and lower case(asset_result.asset_criticality) != &#34;unknown&#34;&#10;  then lower case(asset_result.asset_criticality)&#10;&#10;  /* 🔴 2. TESTFALL-FALLBACK */&#10;  else if asset_name != null&#10;  then&#10;    if starts with(asset_name, &#34;DB-&#34;)&#10;    then &#34;high&#34;&#10;&#10;    else if starts with(asset_name, &#34;AUTH-&#34;)&#10;    then &#34;high&#34;&#10;&#10;    else if starts with(asset_name, &#34;CRM-&#34;)&#10;    then &#34;high&#34;&#10;&#10;    else &#34;low&#34;&#10;&#10;  /* 🟡 3. FINAL */&#10;  else &#34;low&#34;,&#10;&#10;&#10;asset_criticality_label:&#10;  upper case(asset_criticality),&#10;&#10;&#10;&#10;&#10;&#10;&#10;&#10;&#10;/* ---------------- VISIBILITY ---------------- */&#10;&#10;asset_visible:&#10;&#10;contains(&#10;  string(agent_plan.tools),&#10;  &#34;asset_lookup&#34;&#10;),&#10;&#10;&#10;&#10;  &#10;&#10;&#10;&#10;/* ---------------- THREAT LEVEL ---------------- */&#10;&#10;threat_level:&#10;&#10;  if is_gdpr_relevant&#10;  then &#34;CRITICAL&#34;&#10;&#10;  else if threat_category = &#34;DATA_BREACH&#34;&#10;  then &#34;CRITICAL&#34;&#10;&#10;  else if threat_category = &#34;PROXY&#34;&#10;  then &#34;HIGH&#34;&#10;&#10;  else if threat_category = &#34;SCANNING&#34;&#10;  then &#34;MEDIUM&#34;&#10;&#10;  else if threat_category = &#34;SYSTEM&#34;&#10;  then &#34;MEDIUM&#34;&#10;&#10;  else &#34;LOW&#34;,&#10;&#10;&#10;severity_badge_class:&#10;&#10;  if threat_level = &#34;CRITICAL&#34;&#10;  then &#34;badge-critical&#34;&#10;&#10;  else if threat_level = &#34;HIGH&#34;&#10;  then &#34;badge-high&#34;&#10;&#10;  else if threat_level = &#34;MEDIUM&#34;&#10;  then &#34;badge-medium&#34;&#10;&#10;  else &#34;badge-low&#34;,&#10;&#10;&#10;&#10;  &#10;&#10;  &#10;&#10;/* ---------------- RISK SCORE ---------------- */&#10;&#10;risk_score:&#10;&#10;  (&#10;    if lower case(asset_criticality) = &#34;high&#34;&#10;       and threat_level = &#34;CRITICAL&#34;&#10;    then 60&#10;&#10;    else if lower case(asset_criticality) = &#34;high&#34;&#10;         and threat_level = &#34;HIGH&#34;&#10;    then 50&#10;&#10;    else if threat_level = &#34;MEDIUM&#34;&#10;    then 40&#10;&#10;    else 25&#10;  )&#10;&#10;  + (if is_gdpr_relevant then 30 else 0)&#10;&#10;  + (&#10;      if threat_category = &#34;DATA_BREACH&#34;&#10;      then 25&#10;      else 0&#10;    )&#10;&#10;  + (&#10;      if threat_category = &#34;PROXY&#34;&#10;      then 15&#10;      else 0&#10;    )&#10;&#10;  + (&#10;      if threat_category = &#34;SCANNING&#34;&#10;      then 10&#10;      else 0&#10;    )&#10;&#10;  + (&#10;      if contains(topic,&#34;mehrere verbindungen&#34;)&#10;      then 10&#10;      else 0&#10;    ),&#10;&#10;&#10;risk_score_capped:&#10;  min(100, risk_score),&#10;  &#10;  &#10;/* ---------------- INCIDENT IP ---------------- */&#10;&#10;incident_ip:&#10;&#10;  if incident_ip != null &#10;     and incident_ip != &#34;&#34;&#10;     and incident_ip != &#34;Unbekannt&#34;&#10;  then incident_ip&#10;&#10;  else if threat_intel != null &#10;       and threat_intel.ip != null&#10;       and threat_intel.ip != &#34;&#34;&#10;  then threat_intel.ip&#10;&#10;  else &#34;Unbekannt&#34;,&#10;&#10;/* ---------------- UNKNOWN SOURCE FLAG ---------------- */&#10;&#10;has_unknown_source:&#10;&#10;  incident_ip = &#34;Unbekannt&#34;&#10;  or threat_host = &#34;Unbekannt&#34;,  &#10;&#10;&#10;&#10;&#10;&#10;&#10;&#10;&#10;&#10;/* ======================= FINAL RISK LEVEL with GROUPING ======================= */&#10;&#10;&#10;/* ------------------- GROUPING START ------------------- */&#10;&#10;attack_severity_group:&#10;&#10;  /* 🔴 DATA EXFILTRATION */&#10;  if threat_pattern = &#34;DATA_EXFILTRATION&#34;&#10;     or threat_category = &#34;DATA_BREACH&#34;&#10;  then &#34;CRITICAL&#34;&#10;&#10;  /* 🔴 SYSTEM ANOMALY */&#10;  else if threat_pattern = &#34;SYSTEM_ANOMALY&#34;&#10;       and impact = &#34;1&#34;&#10;  then &#34;HIGH&#34;&#10;&#10;  /* 🔴 TARGETED ACCESS */&#10;  else if threat_pattern = &#34;TARGETED_ACCESS&#34;&#10;  then &#34;HIGH&#34;&#10;&#10;  /* 🔴 PROXY */&#10;  else if threat_pattern = &#34;PROXY&#34;&#10;  then &#34;HIGH&#34;&#10;&#10;  /* 🟠 SCANNING */&#10;  else if threat_pattern = &#34;SCAN&#34;&#10;  then &#34;MEDIUM&#34;&#10;&#10;  else &#34;LOW&#34;,&#10;&#10;&#10;threat_severity_group:&#10;&#10;  if threat_category = &#34;DATA_BREACH&#34;&#10;  then &#34;CRITICAL&#34;&#10;&#10;  else if threat_category = &#34;PROXY&#34;&#10;       or threat_category = &#34;SYSTEM&#34;&#10;  then &#34;HIGH&#34;&#10;&#10;  else if threat_category = &#34;SCANNING&#34;&#10;  then &#34;MEDIUM&#34;&#10;&#10;  else &#34;LOW&#34;,&#10;&#10;&#10;/* ------------------- GROUPING END ------------------- */&#10;&#10;&#10;&#10;&#10;risk_level:&#10;&#10;  /* 🔥 BEHAVIOR OVERRIDE */&#10;  if behavior_risk_boost = 2&#10;  then &#34;CRITICAL&#34;&#10;&#10;  /* 🟢 KEIN ECHTER INCIDENT */&#10;  else if detect_real_incident_result.is_real_incident = false&#10;  then &#34;LOW&#34;&#10;&#10;  /* 🔴 DSGVO + DATA BREACH */&#10;  else if is_gdpr_relevant&#10;       and (&#10;         threat_pattern = &#34;DATA_EXFILTRATION&#34;&#10;         or threat_category = &#34;DATA_BREACH&#34;&#10;       )&#10;  then &#34;CRITICAL&#34;&#10;&#10;  /* 🔴 DSGVO */&#10;  else if is_gdpr_relevant&#10;  then &#34;HIGH&#34;&#10;&#10;  /* 🔴 DATA BREACH */&#10;  else if attack_severity_group = &#34;CRITICAL&#34;&#10;       or threat_severity_group = &#34;CRITICAL&#34;&#10;  then &#34;CRITICAL&#34;&#10;&#10;  /* 🔴 HIGH */&#10;  else if attack_severity_group = &#34;HIGH&#34;&#10;       or threat_severity_group = &#34;HIGH&#34;&#10;  then &#34;HIGH&#34;&#10;&#10;  /* 🟠 MEDIUM */&#10;  else if attack_severity_group = &#34;MEDIUM&#34;&#10;       or threat_severity_group = &#34;MEDIUM&#34;&#10;  then &#34;MEDIUM&#34;&#10;&#10;  /* 🔵 SCORE FALLBACK */&#10;  else if risk_score_capped &#62;= 70&#10;  then &#34;HIGH&#34;&#10;&#10;  else if risk_score_capped &#62;= 40&#10;  then &#34;MEDIUM&#34;&#10;&#10;  else &#34;LOW&#34;,&#10;&#10;&#10;risk_level_lower:&#10;  lower case(risk_level),&#10;&#10;&#10;/* 🔥 RISK ORIGIN */&#10;&#10;risk_origin:&#10;&#10;  if behavior_risk_boost = 2&#10;  then &#34;BEHAVIOR_OVERRIDE&#34;&#10;&#10;  else if is_gdpr_relevant&#10;  then &#34;GDPR&#34;&#10;&#10;  else if attack_severity_group = &#34;CRITICAL&#34;&#10;       or attack_severity_group = &#34;HIGH&#34;&#10;       or threat_severity_group = &#34;CRITICAL&#34;&#10;       or threat_severity_group = &#34;HIGH&#34;&#10;  then &#34;ATTACK_SEVERITY&#34;&#10;&#10;  else &#34;STANDARD&#34;,&#10;&#10;  &#10;&#10;/* ---------------- UI LEVEL (NEU SAUBER) ---------------- */&#10;&#10;/* 👉 DAS IST JETZT DER ANZEIGE-WERT */&#10;display_risk:&#10;  risk_level,&#10;&#10;display_risk_lower:&#10;  lower case(display_risk),&#10;&#10;&#10;/* 🔥 BADGE JETZT AUF RISK LEVEL */&#10;severity_badge_class:&#10;&#10;  if risk_level = &#34;CRITICAL&#34; then &#34;badge-critical&#34;&#10;  else if risk_level = &#34;HIGH&#34; then &#34;badge-high&#34;&#10;  else if risk_level = &#34;MEDIUM&#34; then &#34;badge-medium&#34;&#10;  else &#34;badge-low&#34;,&#10;&#10;  &#10;&#10;&#10;  &#10;&#10;  &#10;/* ---------------- FINAL ACTION ---------------- */&#10;&#10;base_action:&#10;&#10;  /* 🟢 KEIN INCIDENT */&#10;  if detect_real_incident_result.is_real_incident = false&#10;  then &#34;ignore&#34;&#10;&#10;  /* 🔴 DSGVO */&#10;  else if is_gdpr_relevant&#10;  then &#34;contain&#34;&#10;&#10;  /* 🔴 DATA EXFILTRATION */&#10;  else if threat_pattern = &#34;DATA_EXFILTRATION&#34;&#10;  then &#34;contain&#34;&#10;&#10;  /* 🔴 TARGETED ACCESS */&#10;  else if threat_pattern = &#34;TARGETED_ACCESS&#34;&#10;  then &#34;investigate&#34;&#10;&#10;  /* 🔴 SYSTEM ANOMALY */&#10;  else if threat_pattern = &#34;SYSTEM_ANOMALY&#34;&#10;  then &#34;investigate&#34;&#10;&#10;  /* 🟠 PROXY */&#10;  else if threat_pattern = &#34;PROXY&#34;&#10;  then &#34;investigate&#34;&#10;&#10;  /* 🟡 SCANNING */&#10;  else if threat_pattern = &#34;SCAN&#34;&#10;  then &#34;monitor&#34;&#10;&#10;  /* 🔵 FALLBACK */&#10;  else &#34;investigate&#34;&#10;&#10;  &#10;&#10; &#10;}" resultVariable="incident_object" />
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_1xsrq63</bpmn:incoming>
        <bpmn:outgoing>Flow_1w0atz5</bpmn:outgoing>
      </bpmn:scriptTask>
      <bpmn:scriptTask id="Activity_07u2cg9" name="ISO Compliance Enrichment">
        <bpmn:extensionElements>
          <zeebe:script expression="=put all(&#10;  if incident_object = null then {} else incident_object,&#10;&#10;  {&#10;&#10;    /* ========================================================= */&#10;    /* ISO CONTROLS RENDERED                                     */&#10;    /* ========================================================= */&#10;&#10;    iso_controls:&#10;&#10;      for c in (if iso_controls != null then iso_controls else []) return {&#10;&#10;        text:&#10;          c.text,&#10;&#10;        status:&#10;          c.status,&#10;&#10;        rendered:&#10;&#10;          c.text + &#34;  [&#34; +&#10;&#10;          (&#10;            if c.status = &#34;ERFUELLT&#34;&#10;            then &#34;NICHT BETROFFEN&#34;&#10;&#10;            else if c.status = &#34;TEILWEISE BETROFFEN&#34;&#10;            then &#34;TEILWEISE BETROFFEN&#34;&#10;&#10;            else &#34;ZU ÜBERPRÜFEN&#34;&#10;          )&#10;&#10;          + &#34;]&#34;&#10;      },&#10;&#10;&#10;&#10;    /* ========================================================= */&#10;    /* ISO MAPPING TEXT                                          */&#10;    /* ========================================================= */&#10;&#10;    iso_mapping_rendered:&#10;&#10;      string join(&#10;&#10;        for c in (if iso_controls != null then iso_controls else []) return&#10;&#10;          c.text + &#34;  [&#34; +&#10;&#10;          (&#10;            if c.status = &#34;ERFUELLT&#34;&#10;            then &#34;NICHT BETROFFEN&#34;&#10;&#10;            else if c.status = &#34;TEILWEISE BETROFFEN&#34;&#10;            then &#34;TEILWEISE BETROFFEN&#34;&#10;&#10;            else &#34;ZU ÜBERPRÜFEN&#34;&#10;          )&#10;&#10;          + &#34;]&#34;,&#10;&#10;        &#34;\n&#34;&#10;      ),&#10;&#10;    iso_control_count:&#10;&#10;      count(&#10;        if iso_controls != null&#10;        then iso_controls&#10;        else []&#10;      ),&#10;&#10;&#10;&#10;    /* ========================================================= */&#10;    /* UI LABELS                                                 */&#10;    /* ========================================================= */&#10;&#10;    risk_label:&#10;&#10;      if incident_object.risk_level = null&#10;      then null&#10;&#10;      else upper case(&#10;&#10;        if upper case(incident_object.risk_level) = &#34;CRITICAL&#34;&#10;        then &#34;KRITISCH&#34;&#10;&#10;        else if upper case(incident_object.risk_level) = &#34;HIGH&#34;&#10;        then &#34;HOCH&#34;&#10;&#10;        else if upper case(incident_object.risk_level) = &#34;MEDIUM&#34;&#10;        then &#34;MITTEL&#34;&#10;&#10;        else if upper case(incident_object.risk_level) = &#34;LOW&#34;&#10;        then &#34;NIEDRIG&#34;&#10;&#10;        else incident_object.risk_level&#10;      ),&#10;&#10;&#10;&#10;    action_label:&#10;&#10;      if incident_object.action = null&#10;      then null&#10;&#10;      else upper case(&#10;&#10;        if upper case(incident_object.action) = &#34;CONTAIN&#34;&#10;        then &#34;EINDÄMMEN&#34;&#10;&#10;        else if upper case(incident_object.action) = &#34;INVESTIGATE&#34;&#10;        then &#34;UNTERSUCHEN&#34;&#10;&#10;        else if upper case(incident_object.action) = &#34;MONITOR&#34;&#10;        then &#34;ÜBERWACHEN&#34;&#10;&#10;        else if upper case(incident_object.action) = &#34;IGNORE&#34;&#10;        then &#34;IGNORIEREN&#34;&#10;&#10;        else if upper case(incident_object.action) = &#34;ESCALATE&#34;&#10;        then &#34;ESKALIEREN&#34;&#10;&#10;        else upper case(incident_object.action)&#10;      ),&#10;&#10;&#10;&#10;    action_priority_label:&#10;&#10;      if incident_object.action_priority = null&#10;      then null&#10;&#10;      else upper case(&#10;&#10;        if upper case(incident_object.action_priority) = &#34;CRITICAL&#34;&#10;        then &#34;KRITISCH&#34;&#10;&#10;        else if upper case(incident_object.action_priority) = &#34;HIGH&#34;&#10;        then &#34;HOCH&#34;&#10;&#10;        else if upper case(incident_object.action_priority) = &#34;MEDIUM&#34;&#10;        then &#34;MITTEL&#34;&#10;&#10;        else if upper case(incident_object.action_priority) = &#34;LOW&#34;&#10;        then &#34;NIEDRIG&#34;&#10;&#10;        else incident_object.action_priority&#10;      )&#10;&#10;  }&#10;)" resultVariable="incident_object" />
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_1rkls3u</bpmn:incoming>
        <bpmn:outgoing>Flow_0itfbyx</bpmn:outgoing>
      </bpmn:scriptTask>
      <bpmn:sequenceFlow id="Flow_0itfbyx" sourceRef="Activity_07u2cg9" targetRef="Build_Investigation_Report" />
      <bpmn:scriptTask id="Activity_1d33b1r" name="Evaluate ISO Controls">
        <bpmn:extensionElements>
          <zeebe:script expression="=for c in&#10;  (&#10;    if not(&#10;      some x in&#10;        (&#10;          if not(&#10;            some y in iso_controls satisfies starts with(y.text, &#34;A.16.&#34;)&#10;          )&#10;          then append(&#10;            iso_controls,&#10;            {&#10;              text: &#34;A.16.X Behandlung von Sicherheitsvorfällen&#34;&#10;            }&#10;          )&#10;          else iso_controls&#10;        )&#10;      satisfies starts with(x.text, &#34;A.18.&#34;)&#10;    )&#10;    then append(&#10;      (&#10;        if not(&#10;          some y in iso_controls satisfies starts with(y.text, &#34;A.16.&#34;)&#10;        )&#10;        then append(&#10;          iso_controls,&#10;          {&#10;            text: &#34;A.16.X Behandlung von Sicherheitsvorfällen&#34;&#10;          }&#10;        )&#10;        else iso_controls&#10;      ),&#10;      {&#10;        text: &#34;A.18.X Compliance und Datenschutz&#34;&#10;      }&#10;    )&#10;    else&#10;      (&#10;        if not(&#10;          some y in iso_controls satisfies starts with(y.text, &#34;A.16.&#34;)&#10;        )&#10;        then append(&#10;          iso_controls,&#10;          {&#10;            text: &#34;A.16.X Behandlung von Sicherheitsvorfällen&#34;&#10;          }&#10;        )&#10;        else iso_controls&#10;      )&#10;  )&#10;return {&#10;&#10;  text: c.text,&#10;&#10;  status:&#10;&#10;/* ================= RECONNAISSANCE ================= */&#10;&#10;if incident_object.sanitized_attack_stage != null&#10;   and (&#10;     contains(lower case(incident_object.sanitized_attack_stage), &#34;recon&#34;)&#10;     or contains(lower case(incident_object.sanitized_attack_stage), &#34;scan&#34;)&#10;   )&#10;then&#10;  if starts with(c.text, &#34;A.12.&#34;)&#10;  then &#34;ERFUELLT&#34;&#10;&#10;  else if starts with(c.text, &#34;A.13.&#34;)&#10;  then &#34;TEILWEISE BETROFFEN&#34;&#10;&#10;  else &#34;TEILWEISE BETROFFEN&#34;&#10;&#10;&#10;/* ================= INITIAL ACCESS ================= */&#10;&#10;else if incident_object.sanitized_attack_stage != null&#10;   and (&#10;     contains(lower case(incident_object.sanitized_attack_stage), &#34;initial&#34;)&#10;     or contains(lower case(incident_object.sanitized_attack_stage), &#34;access&#34;)&#10;   )&#10;then&#10;  if starts with(c.text, &#34;A.9.&#34;)&#10;  then &#34;TEILWEISE BETROFFEN&#34;&#10;&#10;  else if starts with(c.text, &#34;A.8.&#34;)&#10;  then &#34;TEILWEISE BETROFFEN&#34;&#10;&#10;  else &#34;TEILWEISE BETROFFEN&#34;&#10;&#10;&#10;/* ================= EXECUTION ================= */&#10;&#10;else if incident_object.sanitized_attack_stage != null&#10;   and (&#10;     contains(lower case(incident_object.sanitized_attack_stage), &#34;execution&#34;)&#10;     or contains(lower case(incident_object.sanitized_attack_stage), &#34;execute&#34;)&#10;   )&#10;then&#10;  if starts with(c.text, &#34;A.14.&#34;)&#10;  then &#34;TEILWEISE BETROFFEN&#34;&#10;&#10;  else if starts with(c.text, &#34;A.12.&#34;)&#10;  then &#34;TEILWEISE BETROFFEN&#34;&#10;&#10;  else &#34;TEILWEISE BETROFFEN&#34;&#10;&#10;&#10;/* ================= EXFILTRATION ================= */&#10;&#10;else if incident_object.sanitized_attack_stage != null&#10;   and contains(lower case(incident_object.sanitized_attack_stage), &#34;exfil&#34;)&#10;then&#10;  if starts with(c.text, &#34;A.12.&#34;)&#10;  then &#34;ERFUELLT&#34;&#10;&#10;  else if starts with(c.text, &#34;A.18.&#34;)&#10;  then &#34;TEILWEISE BETROFFEN&#34;&#10;&#10;  else &#34;NICHT&#34;&#10;&#10;&#10;/* ================= FALLBACK ================= */&#10;&#10;else if starts with(c.text, &#34;A.18.&#34;)&#10;then&#10;  if incident_object.gdpr_relevance = &#34;JA&#34;&#10;  then &#34;TEILWEISE BETROFFEN&#34;&#10;&#10;  else &#34;ERFUELLT&#34;&#10;&#10;else &#34;TEILWEISE BETROFFEN&#34;&#10;}" resultVariable="iso_controls" />
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_19197k3</bpmn:incoming>
        <bpmn:outgoing>Flow_1rkls3u</bpmn:outgoing>
      </bpmn:scriptTask>
      <bpmn:sequenceFlow id="Flow_1rkls3u" sourceRef="Activity_1d33b1r" targetRef="Activity_07u2cg9" />
      <bpmn:sequenceFlow id="Flow_1w0atz5" sourceRef="Unified_Incident_Builder" targetRef="Confidence_Calculation" />
    </bpmn:subProcess>
    <bpmn:sequenceFlow id="Flow_1rq39js" sourceRef="Content_Enrichment" targetRef="ISMS_Incident_Review" />
    <bpmn:endEvent id="Event_1pu30zs" name="Prozess Ende">
      <bpmn:incoming>Flow_0ljujq2</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:userTask id="Audit_Report" name="ISMS Audit Report">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="Incident_Report" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1eiz0y2</bpmn:incoming>
      <bpmn:outgoing>Flow_0ljujq2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_1eiz0y2" sourceRef="Create_Audit_Sections" targetRef="Audit_Report" />
    <bpmn:scriptTask id="Create_Audit_Sections" name="Create Audit Sections">
      <bpmn:extensionElements>
        <zeebe:script expression="=put all(&#10;&#10;  if incident_object = null then {} else incident_object,&#10;&#10;  {&#10;&#10;    /* ================= COLOR BADGES ====================== */&#10;&#10;	risk_badge_class:&#10;&#10;	  if incident_object.risk_level = &#34;LOW&#34;&#10;	  then &#34;badge-green&#34;&#10;&#10;	  else if incident_object.risk_level = &#34;MEDIUM&#34;&#10;	  then &#34;badge-blue&#34;&#10;&#10;	  else if incident_object.risk_level = &#34;HIGH&#34;&#10;	  then &#34;badge-orange&#34;&#10;&#10;	  else if incident_object.risk_level = &#34;CRITICAL&#34;&#10;	  then &#34;badge-red&#34;&#10;&#10;	  else &#34;badge-secondary&#34;,&#10;&#10;&#10;	action_badge_class:&#10;&#10;	  if incident_object.action = &#34;monitor&#34;&#10;	  then &#34;badge-blue&#34;&#10;&#10;	  else if incident_object.action = &#34;investigate&#34;&#10;	  then &#34;badge-orange&#34;&#10;&#10;	  else if incident_object.action = &#34;contain&#34;&#10;	  then &#34;badge-red&#34;&#10;&#10;	  else if incident_object.action = &#34;ignore&#34;&#10;	  then &#34;badge-grey&#34;&#10;&#10;	  else &#34;badge-secondary&#34;,&#10;&#10;	/* ================= DSGVO BADGE ====================== */&#10;&#10;	gdpr_badge_class:&#10;&#10;	  if incident_object.is_gdpr_relevant = true&#10;	  then &#34;badge-red&#34;&#10;&#10;	  else if incident_object.dsgvo_skipped = true&#10;	  then &#34;badge-green&#34;&#10;&#10;	  else &#34;badge-gray&#34;,&#10;    &#10;    /* ================= EXECUTIVE SUMMARY ================= */&#10;&#10;    executive_summary:&#10;&#10;      &#34;Entscheidung: &#34; + upper case(&#10;        string(&#10;          if incident_object.action_label != null&#10;          then incident_object.action_label&#10;          else &#34;Unbekannt&#34;&#10;        )&#10;      ) + &#34;\n&#34;&#10;      +&#10;      &#34;Priorität: &#34; + upper case(&#10;        string(&#10;          if incident_object.action_priority_label != null&#10;          then incident_object.action_priority_label&#10;          else &#34;Unbekannt&#34;&#10;        )&#10;      ) + &#34;\n&#34;&#10;      +&#10;      &#34;Begründung: &#34; +&#10;      (&#10;        if incident_object.llm_explanation_short != null&#10;        then string(incident_object.llm_explanation_short)&#10;        else &#34;Keine Begründung angeben&#34;&#10;      ),&#10;&#10;&#10;    /* ================= TECHNICAL CONTEXT ================= */&#10;&#10;	technical_context:&#10;&#10;	(&#10;	  /* ================= ENRICHED THREAT ================= */&#10;&#10;	  if incident_object.threat_score != null&#10;	   and incident_object.threat_score &#62; 0&#10;&#10;	  then&#10;&#10;		&#34;### &#34; + incident_object.report_labels.threat_intel + &#34; ###\n&#34;&#10;		+&#10;		&#34;Quell-IP: &#34; + string(incident_object.incident_ip) + &#34;\n&#34;&#10;		+&#10;		&#34;Bedrohungshost: &#34; + string(incident_object.threat_host) + &#34;\n&#34;&#10;		+&#10;		&#34;Bedrohungswert: &#34; + string(incident_object.threat_score) + &#34;\n&#34;&#10;		+&#10;		&#34;Bedrohungsstufe: &#34; + string(incident_object.threat_level) + &#34;\n&#34;&#10;		+&#10;		&#34;Offene Ports: &#34;&#10;		+&#10;		(&#10;		  if incident_object.threat_ports != null&#10;			 and count(incident_object.threat_ports) &#62; 0&#10;		  then string join(&#10;			for p in incident_object.threat_ports return string(p),&#10;			&#34;, &#34;&#10;		  )&#10;		  else &#34;none&#34;&#10;		)&#10;&#10;	  else&#10;&#10;		/* ================= FALLBACK ================= */&#10;&#10;		&#34;### BASIC INCIDENT CONTEXT ###\n&#34;&#10;		+&#10;		&#34;Vorfallstyp: &#34; + string(incident_object.threat_category) + &#34;\n&#34;&#10;		+&#10;		&#34;Erkanntes Muster: &#34; + string(incident_object.threat_pattern) + &#34;\n&#34;&#10;		+&#10;		&#34;Quelle: &#34; + string(incident_object.incident_ip) + &#34;\n&#34;&#10;		+&#10;		&#34;Risikobewertung: &#34; + string(incident_object.risk_level)&#10;&#10;	   )&#10;&#10;	   +&#10;&#10;	   (&#10;	  /* ================= ASSET ================= */&#10;&#10;	  if incident_object.asset_visible = true&#10;&#10;	  then&#10;		&#34;\n\n### &#34; + incident_object.report_labels.asset + &#34; ###\n&#34;&#10;		+&#10;		&#34;Systemtyp: &#34; + string(incident_object.asset_type) + &#34;\n&#34;&#10;		+&#10;		&#34;Systemverantwortlicher: &#34; + string(incident_object.asset_owner) + &#34;\n&#34;&#10;		+&#10;		&#34;Kritikalität: &#34; + string(incident_object.asset_criticality_label)&#10;&#10;	  else &#34;&#34;&#10;	),&#10;&#10;    /* ================= HUMAN REVIEW ================= */&#10;&#10;    human_review:&#10;&#10;     incident_object.report_labels.decision + &#34;: &#34;&#10;	+&#10;	(if audit_decision != null&#10;	 then audit_decision&#10;	 else &#34;Ticket erstellt&#34;)&#10;&#10;	+&#10;&#10;	&#34;\n&#34;&#10;&#10;	+&#10;&#10;	incident_object.report_labels.ai_recommendation&#10;	+ &#34;: &#34;&#10;	+ incident_object.report_labels.impact + &#34; &#34;&#10;	+ string(incident_object.impact)&#10;	+ &#34; / &#34;&#10;	+ incident_object.report_labels.urgency + &#34; &#34;&#10;	+ string(incident_object.urgency)&#10;&#10;	+&#10;&#10;	&#34;\n&#34;&#10;&#10;	+&#10;&#10;	incident_object.report_labels.final_priority&#10;	+ &#34;: &#34;&#10;	+ incident_object.report_labels.impact + &#34; &#34;&#10;	+&#10;	(if final_impact != null&#10;	 then string(final_impact)&#10;	 else string(incident_object.impact))&#10;	+ &#34; / &#34;&#10;	+ incident_object.report_labels.urgency + &#34; &#34;&#10;	+&#10;	(if final_urgency != null&#10;	 then string(final_urgency)&#10;	 else string(incident_object.urgency))&#10;&#10;	+&#10;&#10;	&#34;\n&#34;&#10;&#10;	+&#10;&#10;	incident_object.report_labels.auditor_comment&#10;	+ &#34;: &#34;&#10;	+&#10;	(if human_comment != null&#10;	 then human_comment&#10;	 else &#34;Die KI-Empfehlung wurde ohne Änderungen angenommen.&#34;)&#10;&#10;	+&#10;&#10;	(if gdpr_decision = &#34;abort&#34;&#10;	 then&#10;	   &#34;\n\n&#34;&#10;	   + incident_object.report_labels.gdpr_aborted&#10;	   + &#34;\n&#34;&#10;	   + incident_object.report_labels.reason&#10;	   + &#34;: &#34;&#10;	   +&#10;	   (if gdpr_abort_comment != null&#10;		then gdpr_abort_comment&#10;		else &#34;Es wurde kein Grund angegeben.&#34;)&#10;	 else &#34;&#34;)&#10;&#10;	+&#10;&#10;	&#34;\n---\n&#34; +&#10;&#10;	&#34;PROZESSSTATUS: VALIDIERTER VORFALL&#34;,&#10;&#10;    &#10;    /* ================= ACTIONS TAKEN ================= */&#10;&#10;    actions_taken:&#10;&#10;      string join(&#10;&#10;        for step in (&#10;          if incident_object.incident_timeline != null&#10;          then incident_object.incident_timeline&#10;          else []&#10;        )&#10;&#10;        return&#10;&#10;          &#34;👉 &#34; +&#10;&#10;          string(&#10;            if step.step = &#34;DSGVO_SKIPPED&#34;&#10;            then &#34;DSGVO Prüfung nicht eingeleitet&#34;&#10;&#10;            else if step.step = &#34;DSGVO_TICKET_CREATED&#34;&#10;            then &#34;DSGVO Ticket erstellt&#34;&#10;&#10;            else if step.step = &#34;ISO_TICKET_CREATED&#34;&#10;            then &#34;ISO Ticket erstellt&#34;&#10;&#10;            else if step.step = &#34;TICKET_CREATION_SKIPPED&#34;&#10;            then &#34;Der komplette Untersuchungsvorgang wurde abgebrochen!&#34;&#10;&#10;            else step.step&#10;          ) +&#10;&#10;          &#34;:\n&#34; +&#10;&#10;          &#34;Kommentar (&#34; +&#10;&#10;          string(&#10;            if step.reason_source != null&#10;            then step.reason_source&#10;            else &#34;System&#34;&#10;          ) +&#10;&#10;          &#34;, &#34; +&#10;&#10;          string(step.timestamp) +&#10;&#10;          &#34;): &#34; +&#10;&#10;          string(&#10;            if step.reason != null&#10;            then step.reason&#10;            else &#34;keine Angabe&#34;&#10;          )&#10;&#10;      , &#34;\n&#34;),&#10;&#10;&#10;    /* ================= ISO TOPIC ================= */&#10;&#10;	iso_topic:&#10;&#10;		if contains(incident_object.investigation_report, &#34;VORFALL&#34;)&#10;		then&#10;		  trim(&#10;			substring before(&#10;			  substring after(&#10;				incident_object.investigation_report,&#10;				&#34;1. VORFALL:&#34;&#10;			  ),&#10;			  &#34;2. &#34;&#10;			)&#10;		  )&#10;		else&#10;		  &#34;N/A&#34;,&#10;&#10;    iso_explanation:&#10;    (if llm_analysis.llm_explanation != null&#10;		then string(llm_analysis.llm_explanation)&#10;		else &#34;&#34;),&#10;&#10;    &#10;&#10;    /* ================= ISO MAPPING ================= */&#10;&#10;	iso_mapping:&#10;&#10;		if contains(incident_object.investigation_report, &#34;ISO 27001 MAPPING&#34;)&#10;		then&#10;		  trim(&#10;			substring before(&#10;			  substring after(&#10;				incident_object.investigation_report,&#10;				&#34;3. ISO 27001 MAPPING:&#34;&#10;			  ),&#10;			  &#34;---&#34;&#10;			)&#10;		  )&#10;		else&#10;  &#34;N/A&#34;,&#10;&#10;&#10;    /* ================= DSGVO STATUS ================= */&#10;&#10;    dsgvo_status:&#10;&#10;      &#34;Relevanz: &#34; +&#10;      string(&#10;        if incident_object.is_gdpr_relevant = true&#10;        then &#34;JA&#34;&#10;        else &#34;NEIN&#34;&#10;      ) + &#34;\n&#34; +&#10;&#10;      &#34;DSGVO Entscheidung: &#34; +&#10;      string(&#10;        if gdpr_decision != null and audit_decision != &#34;Ticket erstellen&#34;&#10;        then &#34;Kompletter Untersuchungsvorgang abgebrochen&#34;&#10;        else&#10;          (if gdpr_decision = &#34;start&#34;&#10;           then &#34;Untersuchung wurde eingeleitet&#34;&#10;           else &#34;Untersuchung wurde nicht eingeleitet&#34;)&#10;      )&#10;&#10;  }&#10;&#10;)" resultVariable="incident_object" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0jnoav8</bpmn:incoming>
      <bpmn:outgoing>Flow_1eiz0y2</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:subProcess id="Activity_0uj3i4a" name="ISO POST EVALUATE">
      <bpmn:incoming>Flow_10q65j1</bpmn:incoming>
      <bpmn:outgoing>Flow_0jnoav8</bpmn:outgoing>
      <bpmn:startEvent id="Event_1codhch">
        <bpmn:outgoing>Flow_1qrrhqn</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:scriptTask id="ISO_Post_Evaluate_00" name="ISO Post Evaluate">
        <bpmn:extensionElements>
          <zeebe:script expression="=for c in iso_controls return&#10;&#10;  if c = null then null&#10;&#10;  else {&#10;&#10;    text:&#10;      if c.text != null then c.text else &#34;UNKNOWN&#34;,&#10;&#10;    /* 🔁 PRE STATUS */&#10;    status_pre:&#10;      if c.status != null then c.status else &#34;ERFUELLT&#34;,&#10;&#10;    /* 🔥 STATUS POST (ZENTRALE LOGIK) */&#10;    status_post:&#10;&#10;      /* ================= A.16 ================= */&#10;      if c.text != null and starts with(c.text, &#34;A.16.&#34;)&#10;      then&#10;        if detect_real_incident_result = null &#10;           or detect_real_incident_result.is_real_incident != true&#10;        then &#34;ERFUELLT&#34;&#10;&#10;        else if process_failure = true&#10;        then &#34;NICHT&#34;&#10;&#10;        else if incident_object != null &#10;             and incident_object.ticket_created_iso = true&#10;        then &#34;TEILWEISE BETROFFEN&#34;&#10;&#10;        else &#34;NICHT&#34;&#10;&#10;      /* ================= A.18 ================= */&#10;      else if c.text != null and starts with(c.text, &#34;A.18.&#34;)&#10;      then&#10;        if detect_real_incident_result = null &#10;           or detect_real_incident_result.is_real_incident != true&#10;        then &#34;ERFUELLT&#34;&#10;&#10;        else if incident_object = null &#10;             or incident_object.gdpr_relevance != &#34;JA&#34;&#10;        then &#34;ERFUELLT&#34;&#10;&#10;        else if process_failure = true&#10;        then &#34;NICHT&#34;&#10;&#10;        else if incident_object != null &#10;             and incident_object.ticket_created_dsgvo = true&#10;        then &#34;TEILWEISE BETROFFEN&#34;&#10;&#10;        else &#34;NICHT&#34;&#10;&#10;      /* ================= REST ================= */&#10;      else&#10;        if c.status != null then c.status else &#34;ERFUELLT&#34;,&#10;&#10;    /* 🔁 CHANGE FLAG (KEINE DUPLIKATE MEHR) */&#10;    changed:&#10;      (&#10;        if c.status != null then c.status else &#34;ERFUELLT&#34;&#10;      )&#10;      !=&#10;      (&#10;        /* 👉 nutzt exakt gleiche Logik wie oben */&#10;        if c.text != null and starts with(c.text, &#34;A.16.&#34;)&#10;        then&#10;          if detect_real_incident_result = null &#10;             or detect_real_incident_result.is_real_incident != true&#10;          then &#34;ERFUELLT&#34;&#10;          else if process_failure = true&#10;          then &#34;NICHT&#34;&#10;          else if incident_object != null &#10;               and incident_object.ticket_created_iso = true&#10;          then &#34;TEILWEISE BETROFFEN&#34;&#10;          else &#34;NICHT&#34;&#10;&#10;        else if c.text != null and starts with(c.text, &#34;A.18.&#34;)&#10;        then&#10;          if detect_real_incident_result = null &#10;             or detect_real_incident_result.is_real_incident != true&#10;          then &#34;ERFUELLT&#34;&#10;          else if incident_object = null &#10;               or incident_object.gdpr_relevance != &#34;JA&#34;&#10;          then &#34;ERFUELLT&#34;&#10;          else if process_failure = true&#10;          then &#34;NICHT&#34;&#10;          else if incident_object != null &#10;               and incident_object.ticket_created_dsgvo = true&#10;          then &#34;TEILWEISE BETROFFEN&#34;&#10;          else &#34;NICHT&#34;&#10;&#10;        else if c.status != null then c.status else &#34;ERFUELLT&#34;&#10;      ),&#10;&#10;    /* 🔍 EXPLANATION (MIT PROCESS FAILURE) */&#10;    explanation:&#10;&#10;      /* ================= A.16 ================= */&#10;      if c.text != null and starts with(c.text, &#34;A.16.&#34;)&#10;      then&#10;        if detect_real_incident_result = null &#10;           or detect_real_incident_result.is_real_incident != true&#10;        then &#34;Kein Sicherheitsvorfall&#34;&#10;&#10;        else if process_failure = true&#10;        then &#34;Prozessversagen: Vorfall nicht bearbeitet&#34;&#10;&#10;        else if incident_object != null &#10;             and incident_object.ticket_created_iso = true&#10;        then &#34;Ticket erstellt, Vorfall in Bearbeitung - s. o. &#39;4. Ergriffene Maßnahmen&#39;&#34;&#10;&#10;        else &#34;Vorfall erkannt, keine Bearbeitung gestartet&#34;&#10;&#10;      /* ================= A.18 ================= */&#10;      else if c.text != null and starts with(c.text, &#34;A.18.&#34;)&#10;      then&#10;        if detect_real_incident_result = null &#10;           or detect_real_incident_result.is_real_incident != true&#10;        then &#34;Kein Sicherheitsvorfall&#34;&#10;&#10;        else if incident_object = null &#10;             or incident_object.gdpr_relevance != &#34;JA&#34;&#10;        then &#34;Kein DSGVO-relevanter Vorfall&#34;&#10;&#10;        else if process_failure = true&#10;        then &#34;DSGVO-relevant, keine Maßnahme (Prozessversagen)&#34;&#10;&#10;        else if incident_object != null &#10;             and incident_object.ticket_created_dsgvo = true&#10;        then &#34;DSGVO-Prüfung gestartet (Ticket erstellt) - s. o. &#39;4. Ergriffene Maßnahmen&#39;&#34;&#10;&#10;        else &#34;DSGVO-relevant, keine Maßnahme eingeleitet&#34;&#10;&#10;      else null&#10;  }" resultVariable="iso_controls_final" />
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_12wrfna</bpmn:incoming>
        <bpmn:outgoing>Flow_0cxzoin</bpmn:outgoing>
      </bpmn:scriptTask>
      <bpmn:scriptTask id="ISO_Post_Render" name="ISO Post Render">
        <bpmn:extensionElements>
          <zeebe:script expression="=put all(&#10;  if incident_object = null then {} else incident_object,&#10;&#10;  {&#10;    iso_controls_final_rendered:&#10;&#10;      for c in (&#10;        if iso_controls_final != null&#10;        then iso_controls_final&#10;        else []&#10;      ) return&#10;&#10;        if c = null then null&#10;&#10;        else {&#10;&#10;          text:&#10;            if c.text != null&#10;            then c.text&#10;            else &#34;UNKNOWN&#34;,&#10;&#10;          explanation:&#10;            if c.explanation != null&#10;            then c.explanation&#10;            else null,&#10;&#10;          rendered:&#10;&#10;            (if c.text != null then c.text else &#34;UNKNOWN&#34;)&#10;&#10;            +&#10;&#10;            (&#10;              if c.explanation != null&#10;              then &#34;\n　　　➤ &#34; + c.explanation&#10;              else &#34;&#34;&#10;            )&#10;        }&#10;  }&#10;)" resultVariable="incident_object" />
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_0cxzoin</bpmn:incoming>
        <bpmn:outgoing>Flow_0s23qo5</bpmn:outgoing>
      </bpmn:scriptTask>
      <bpmn:scriptTask id="ISO_Post_Mapping" name="ISO Post Mapping">
        <bpmn:extensionElements>
          <zeebe:script expression="=put all(&#10;  if incident_object = null then {} else incident_object,&#10;&#10;  {&#10;    iso_mapping_rendered_final:&#10;&#10;      string join(&#10;        for c in (&#10;          if incident_object.iso_controls_final_rendered != null &#10;          then incident_object.iso_controls_final_rendered &#10;          else []&#10;        ) return&#10;&#10;          if c != null and c.rendered != null&#10;          then c.rendered&#10;          else &#34;&#34;,&#10;&#10;        &#34;\n&#34;&#10;      ),&#10;&#10;    iso_control_count_final:&#10;&#10;      count(&#10;        for c in (&#10;          if incident_object.iso_controls_final_rendered != null &#10;          then incident_object.iso_controls_final_rendered &#10;          else []&#10;        ) return&#10;&#10;          if c != null then 1 else null&#10;      )&#10;  }&#10;)" resultVariable="incident_object" />
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_0s23qo5</bpmn:incoming>
        <bpmn:outgoing>Flow_1jhbl63</bpmn:outgoing>
      </bpmn:scriptTask>
      <bpmn:sequenceFlow id="Flow_0s23qo5" sourceRef="ISO_Post_Render" targetRef="ISO_Post_Mapping" />
      <bpmn:sequenceFlow id="Flow_0cxzoin" sourceRef="ISO_Post_Evaluate_00" targetRef="ISO_Post_Render" />
      <bpmn:endEvent id="Event_1des4tm">
        <bpmn:incoming>Flow_1jhbl63</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_1qrrhqn" sourceRef="Event_1codhch" targetRef="Process_Failure_Check" />
      <bpmn:sequenceFlow id="Flow_1jhbl63" sourceRef="ISO_Post_Mapping" targetRef="Event_1des4tm" />
      <bpmn:sequenceFlow id="Flow_12wrfna" sourceRef="Process_Failure_Check" targetRef="ISO_Post_Evaluate_00" />
      <bpmn:scriptTask id="Process_Failure_Check" name="Process Failure Check">
        <bpmn:extensionElements>
          <zeebe:script expression="=  if detect_real_incident_result != null&#10;     and detect_real_incident_result.is_real_incident = true&#10;&#10;     and incident_object != null&#10;     and incident_object.gdpr_relevance = &#34;JA&#34;&#10;&#10;     and incident_object.ticket_created_iso != true&#10;&#10;  then true&#10;&#10;  else false" resultVariable="process_failure" />
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_1qrrhqn</bpmn:incoming>
        <bpmn:outgoing>Flow_12wrfna</bpmn:outgoing>
      </bpmn:scriptTask>
    </bpmn:subProcess>
    <bpmn:sequenceFlow id="Flow_10q65j1" sourceRef="Ticket_Creation" targetRef="Activity_0uj3i4a" />
    <bpmn:sequenceFlow id="Flow_0ljujq2" sourceRef="Audit_Report" targetRef="Event_1pu30zs" />
    <bpmn:callActivity id="Call_Scenario_Processor" name="Call Scenario Processor">
      <bpmn:extensionElements>
        <zeebe:calledElement processId="Start_Incident_Type_Selection" propagateAllChildVariables="true" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0mneppf</bpmn:incoming>
      <bpmn:outgoing>Flow_0kepnhr</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:sequenceFlow id="Flow_0kepnhr" sourceRef="Call_Scenario_Processor" targetRef="Activity_1rkk3bi" />
    <bpmn:startEvent id="Start_Process" name="Start Process">
      <bpmn:outgoing>Flow_0mneppf</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_0mneppf" sourceRef="Start_Process" targetRef="Call_Scenario_Processor" />
    <bpmn:scriptTask id="Activity_0tgi495" name="Initialize Timestamp">
      <bpmn:extensionElements>
        <zeebe:script expression="=put all(&#10;  (if incident_object = null then {} else incident_object),&#10;&#10;  {&#10;    report_timestamp:&#10;&#10;      {&#10;        dt: now(),&#10;        localDt: dt + duration(&#34;PT2H&#34;),  // Winterzeit (PT1H, MEZ = UTC+1) – im Sommer auf PT2H ändern&#10;&#10;        day:&#10;          if localDt.day &#60; 10&#10;          then &#34;0&#34; + string(localDt.day)&#10;          else string(localDt.day),&#10;&#10;        month:&#10;          substring(month of year(localDt), 1, 3),&#10;&#10;        year:&#10;          string(localDt.year),&#10;&#10;        hour:&#10;          if localDt.hour &#60; 10&#10;          then &#34;0&#34; + string(localDt.hour)&#10;          else string(localDt.hour),&#10;&#10;        minute:&#10;          if localDt.minute &#60; 10&#10;          then &#34;0&#34; + string(localDt.minute)&#10;          else string(localDt.minute),&#10;&#10;        second:&#10;          if localDt.second &#60; 10&#10;          then &#34;0&#34; + string(localDt.second)&#10;          else string(localDt.second),&#10;&#10;        formatted:&#10;          day + &#34;.&#34; + month + &#34; &#34; + year + &#34; &#34; +&#10;          hour + &#34;:&#34; + minute + &#34;:&#34; + second&#10;      }.formatted&#10;  }&#10;)" resultVariable="incident_object" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1jzlpls</bpmn:incoming>
      <bpmn:outgoing>Flow_0r6uqpc</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:subProcess id="Ticket_Creation" name="Ticket Creation">
      <bpmn:incoming>Flow_0r6uqpc</bpmn:incoming>
      <bpmn:outgoing>Flow_10q65j1</bpmn:outgoing>
      <bpmn:intermediateThrowEvent id="Event_1wjxhb7">
        <bpmn:incoming>Ticketerstellen</bpmn:incoming>
      </bpmn:intermediateThrowEvent>
