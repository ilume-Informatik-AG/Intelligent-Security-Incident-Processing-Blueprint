      "content": "<!DOCTYPE html>\n<html lang=\"de\">\n<head>\n  <meta charset=\"UTF-8\">\n  <title>Sicherheitsaudit-Bericht</title>\n\n  <style>\n\n    /* ================= GLOBAL ================= */\n\n    body {\n      font-family: Arial, Helvetica, sans-serif;\n      font-size: 12px;\n      line-height: 1.5;\n      color: #222;\n      margin: 30px;\n    }\n\n    h1 {\n      font-size: 22px;\n      margin-bottom: 10px;\n      border-bottom: 2px solid #333;\n      padding-bottom: 5px;\n    }\n\n\th2 {\n\t  font-size: 16px;\n\t  font-weight: 700;\n\t  letter-spacing:0.4px;\n\t  margin-top: 18px;\n\t  margin-bottom: 12px;\n\t  color: #111;\n\n\t  border-left: 4px solid #2f3b52;\n\t  border-radius:4px;\n\t  padding-left: 10px;\n\n\t  background: linear-gradient(to right, #e6f3ff, transparent);\n\t  padding-top: 4px;\n\t  padding-bottom: 4px;\n\t}\n\n    .section {\n      margin-bottom: 20px;\n    }\n\n    /* ================= BOX ================= */\n\n    .box {\n      padding: 10px;\n      border: 1px solid #ddd;\n      border-radius: 6px;\n      background: #f4f4f4;\n    }\n\n    /* ================= TEXT ================= */\n\n    .mono {\n      font-family: Consolas, monospace;\n      white-space: pre-line;\n\t  color:var(--color-text-primary,#1f2a38);\n    }\n\n    /* ================= BADGES ================= */\n\n    .badge {\n      display: inline-block;\n      padding: 3px 10px;\n      border-radius: 12px;\n      font-weight: bold;\n      font-size: 11px;\n      margin-left: 6px;\n\t  color:var(--color-text-primary,#1f2a38);\n    }\n\n    .badge-green {\n      background: #8BC34A;\n      color: #fff;\n    }\n\n    .badge-blue {\n      background: #4FC3F7;\n      color: #fff;\n    }\n\n    .badge-orange {\n      background: #F57C00;\n      color: #fff;\n    }\n\n    .badge-red {\n      background: #E53935;\n      color: #fff;\n    }\n\n    .badge-grey {\n      background: #6c757d;\n      color: #fff;\n    }\n\n    .badge-secondary {\n      background: #999;\n      color: #fff;\n    }\n\n    /* ================= HEADER ================= */\n\n    .header {\n      display: flex;\n      justify-content: space-between;\n      align-items: center;\n    }\n\n    .meta {\n      font-size: 11px;\n      color:var(--color-text-primary,#1f2a38);\n    }\n\n    /* ================= PDF ================= */\n\n    @page {\n      size: A4;\n      margin: 20mm;\n    }\n\n    @media print {\n      body {\n        margin: 0;\n      }\n    }\n\n  </style>\n</head>\n\n<body>\n\n  <!-- HEADER -->\n\t<div class=\"header\">\n\t  <h1><strong>Sicherheitsaudit-Bericht</strong></h1>\n\n\t  <div class=\"meta\" style=\"text-align:right;\">\n\n<div style=\"margin-right: 200px; margin-bottom: 40px; height: 2px; width: 2px; box-shadow: #f8f9fb 0 0,#f8f9fb 0 1px,#f8f9fb 0 2px,#f8f9fb 0 3px,#f8f9fb 0 4px,#f8f9fb 0 5px,#f8f9fb 0 6px,#f8f9fb 0 7px,#f8f9fb 0 8px,#f8f9fb 0 9px,#f8f9fb 0 10px,#f8f9fb 0 11px,#f8f9fb 0 12px,#f7f9fb 0 13px,#f4fbfc 0 14px,#f2fcfd 0 15px,#f3fbfe 0 16px,#f5fafe 0 17px,#f7f9fd 0 18px,#f9f9fa 0 19px,#faf9f6 0 20px,#faf8f1 0 21px,#f9f6ee 0 22px,#fbf8f2 0 23px,#fffcfb 0 24px,#fffbff 0 25px,#fcf6ff 0 26px,#fdf5ff 0 27px,#fef7ff 0 28px,#fcf7f3 0 29px,#fbf6f7 0 30px,#fffaff 0 31px,#fffdfd 0 32px,#f7f5ee 0 33px,#f4f4e5 0 34px,#fcfdef 0 35px,#f9faf4 0 36px,#f8f8ff 0 37px,#f6f6ff 0 38px,#f5f8ff 0 39px,#f5f9ff 0 40px,#f4fdf2 0 41px,#f5fcf1 0 42px,#f7f3ff 0 43px,#fefaff 0 44px,#fdfdf2 0 45px,#fbfafa 0 46px,#fcfbff 0 47px,#fdfdfb 0 48px,#fdfef8 0 49px,#fdfbfb 0 50px,#fbf6ff 0 51px,#f9f1ff 0 52px,#fbf3ff 0 53px,#fef5f7 0 54px,#fff4fe 0 55px,#fef3ff 0 56px,#faf7fe 0 57px,#f8f9fb 0 58px,#f8f9fb 1px 0,#f8f9fb 1px 1px,#f8f9fb 1px 2px,#f8f9fb 1px 3px,#f8f9fb 1px 4px,#f8f9fb 1px 5px,#f8f9fb 1px 6px,#f8f9fb 1px 7px,#f8f9fb 1px 8px,#f8f9fb 1px 9px,#f8f9fb 1px 10px,#f8f9fb 1px 11px,#f8f9fb 1px 12px,#f7f9fb 1px 13px,#f4fbfa 1px 14px,#f3fcfb 1px 15px,#f3fbfd 1px 16px,#f5fafe 1px 17px,#f7f9fe 1px 18px,#f9f9fc 1px 19px,#faf9f9 1px 20px,#fefcf9 1px 21px